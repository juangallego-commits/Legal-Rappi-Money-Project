    .delivery-option .do-icon { font-size:20px; display:block; margin-bottom:4px; }
    .delivery-option .do-name { font-weight:700; font-size:12px; }
    .delivery-option .do-desc { font-size:10px; color:var(--text-2); margin-top:2px; }

    /* Advanced config toggle */
    .adv-toggle { display:flex; align-items:center; gap:8px; padding:12px 16px; background:var(--bg-3); border:1px solid var(--border); border-radius:var(--radius); cursor:pointer; transition:all var(--transition); margin-top:12px; }
    .adv-toggle:hover { border-color:var(--border-hover); }
    .adv-toggle i { color:var(--text-3); transition:transform 0.3s; font-size:12px; }
