    .adv-body { display:none; padding:16px; background:var(--bg-3); border:1px solid var(--border); border-top:none; border-radius:0 0 var(--radius) var(--radius); }
    .adv-body.open { display:block; }

    /* Data transfer alert */
    .dt-alert { background:var(--warning-muted); border:2px solid rgba(255,184,0,0.25); border-radius:var(--radius-lg); padding:20px; margin-top:16px; }
    .dt-alert h4 { font-size:13px; font-weight:700; color:var(--warning); margin-bottom:8px; display:flex; align-items:center; gap:8px; }
    .dt-alert p { font-size:12px; color:var(--text-1); line-height:1.6; }
    .dt-alert ol { font-size:12px; color:var(--text-1); margin:8px 0 12px 16px; line-height:1.8; }
    .dt-check { display:flex; align-items:flex-start; gap:10px; padding:12px; background:var(--bg-2); border:1.5px solid var(--border); border-radius:var(--radius); cursor:pointer; margin-top:12px; }
