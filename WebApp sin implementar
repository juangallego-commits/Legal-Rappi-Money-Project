  // Override saveDraft to show indicator  
  var \_origSaveDraft \= saveDraft;  
  saveDraft \= function() {  
    \_origSaveDraft();  
    showDraftIndicator();  
  };

  // \==========================================================  
  // PHASE 2: HELP CENTER  
  // \==========================================================  
  function showHelpCenter() {  
    allPages.forEach(function(p) {  
      var el \= document.getElementById(p);  
      if (el) el.classList.add('hidden');  
    });  
    document.getElementById('helpCenterPage').classList.remove('hidden');  
    window.scrollTo(0, 0);  
  }

  function hideHelpCenter() {  
    document.getElementById('helpCenterPage').classList.add('hidden');  
    document.getElementById('landingPage').classList.remove('hidden');  
    window.scrollTo(0, 0);  
  }

  function sendHelpFeedback() {  
    var text \= document.getElementById('helpFeedbackText').value.trim();  
    if (\!text) { alert('Por favor escribe tu feedback antes de enviar.'); return; }

    google.script.run  
      .withSuccessHandler(function() {  
        document.getElementById('helpFeedbackText').value \= '';  
        var msg \= document.getElementById('helpFeedbackSuccess');  
        msg.classList.remove('hidden');  
        setTimeout(function() { msg.classList.add('hidden'); }, 3000);  
      })  
      .withFailureHandler(function(err) {  
        console.error('Feedback error:', err);  
        alert('Error al enviar feedback. Intenta de nuevo.');  
      })  
      .saveFeedback(text);  
  }

  // \==========================================================  
  // PHASE 2: DATA TRANSFER  
  // \==========================================================  
  function showDataTransferModal() {  
    showModal('dataTransferModal');  
  }

  function hideDataTransferModal() {  
    hideModal('dataTransferModal');  
  }

  function confirmDataTransferAgreement() {  
    document.getElementById('hDataTransferConfirmed').value \= 'true';  
    hideModal('dataTransferModal');  
    submitForm();  
  }

  // \==========================================================  
  // PHASE 2: TOGGLE FORM FIELDS (Cashback vs Concurso)  
  // \==========================================================  
  function toggleFormFields() {  
    var cashback \= document.getElementById('section-cashback');  
    var concurso \= document.getElementById('section-concurso');  
    if (\!cashback || \!concurso) return;

    if (selectedType \=== 'Cashback') {  
      cashback.classList.remove('hidden');  
      concurso.classList.add('hidden');  
    } else if (selectedType \=== 'Concurso') {  
      cashback.classList.add('hidden');  
      concurso.classList.remove('hidden');  
    } else {  
      cashback.classList.add('hidden');  
      concurso.classList.add('hidden');  
    }  
  }

  // \==========================================================  
  // PHASE 2: AUTOCOMPLETE  
  // \==========================================================  
  function showShopAutocomplete(input) {  
    var value \= input.value.toLowerCase();  
    var dropdown \= document.getElementById('shopAutocomplete');  
    if (\!dropdown) return;

    if (value.length \< 2\) { dropdown.classList.remove('show'); return; }

    var matches \= frequentShops.filter(function(s) {  
      return s.name.toLowerCase().includes(value);  
    });

    if (matches.length \=== 0\) { dropdown.classList.remove('show'); return; }

    dropdown.innerHTML \= matches.map(function(s) {  
      return '\<div class="autocomplete-item" onmousedown="selectShop(\\'' \+ s.name.replace(/'/g, "\\\\'") \+ '\\',\\'' \+ s.legal.replace(/'/g, "\\\\'") \+ '\\')"\>' \+  
        '\<strong\>' \+ s.name \+ '\</strong\>\<span\>' \+ s.legal \+ '\</span\>\</div\>';  
    }).join('');

    dropdown.classList.add('show');  
  }

  function selectShop(name, legal) {  
    document.getElementById('fShop').value \= name;  
    var orgEl \= document.getElementById('fOrgName');  
    if (orgEl && \!orgEl.value) orgEl.value \= legal;  
    hideAutocomplete();  
    onFieldChange();  
    updatePreview();  
  }

  function showOrganizerAutocomplete(input) {  
    var value \= input.value.toLowerCase();  
    var dropdown \= document.getElementById('organizerAutocomplete');  
    if (\!dropdown) return;

    if (value.length \< 2\) { dropdown.classList.remove('show'); return; }

    var matches \= frequentShops.filter(function(s) {  
      return s.legal.toLowerCase().includes(value) || s.name.toLowerCase().includes(value);  
    });

    if (matches.length \=== 0\) { dropdown.classList.remove('show'); return; }

    dropdown.innerHTML \= matches.map(function(s) {  
      return '\<div class="autocomplete-item" onmousedown="selectOrganizer(\\'' \+ s.legal.replace(/'/g, "\\\\'") \+ '\\')"\>' \+  
        '\<strong\>' \+ s.legal \+ '\</strong\>\<span\>' \+ s.name \+ '\</span\>\</div\>';  
    }).join('');

    dropdown.classList.add('show');  
  }

  function selectOrganizer(legal) {  
    document.getElementById('fOrgName').value \= legal;  
    hideAutocomplete();  
    onFieldChange();  
    updatePreview();  
  }

  function hideAutocomplete() {  
    setTimeout(function() {  
      document.querySelectorAll('.autocomplete-dropdown').forEach(function(el) {  
        el.classList.remove('show');  
      });  
    }, 200);  
  }

  // \==========================================================  
  // PHASE 2: FORM SUBMIT WITH DATA TRANSFER CHECK  
  // \==========================================================  
  // Override submitForm to add data transfer check  
  var \_origSubmitForm \= submitForm;  
  submitForm \= function() {  
    // Check if concurso with physical prize needs data transfer  
    if (selectedType \=== 'Concurso') {  
      var prizeEl \= document.querySelector('input\[name="prizeType"\]:checked');  
      var prizeType \= prizeEl ? prizeEl.value : 'credits';  
      var deliveryEl \= document.querySelector('input\[name="deliveryBy"\]:checked');  
      var deliveryBy \= deliveryEl ? deliveryEl.value : 'rappi';

      if (prizeType \=== 'physical' && deliveryBy \=== 'organizer') {  
        var confirmed \= document.getElementById('hDataTransferConfirmed').value;  
        if (confirmed \!== 'true') {  
          showDataTransferModal();  
          return;  
        }  
      }  
    }  
    \_origSubmitForm();  
  };

  // \==========================================================  
  // PHASE 2: ENHANCED FIELD CHANGE HANDLER  
  // \==========================================================  
  // Hook into onFieldChange to also update preview and save draft  
  var \_origOnFieldChange \= onFieldChange;  
  onFieldChange \= function() {  
    \_origOnFieldChange();  
    if (previewVisible) updatePreview();  
  };

  // \==========================================================  
  // PHASE 2: SHOW/HIDE PREVIEW BASED ON FORM PAGE  
  // \==========================================================  
  // Show preview toggle only on formPage  
  var \_origShowPage \= showPage;  
  showPage \= function(id) {  
    \_origShowPage(id);  
    var toggle \= document.getElementById('previewToggle');  
    if (toggle) {  
      toggle.style.display \= (id \=== 'formPage') ? 'flex' : 'none';  
    }  
    // Close preview if navigating away from form  
    if (id \!== 'formPage' && previewVisible) {  
      previewVisible \= false;  
      var drawer \= document.getElementById('previewDrawer');  
      if (drawer) drawer.classList.remove('open');  
      if (toggle) toggle.classList.remove('active');  
    }  
  };

  // Hide preview toggle initially  
  (function() {  
    var t \= document.getElementById('previewToggle');  
    if (t) t.style.display \= 'none';  
  })();

