        <div class="flex justify-between items-start mb-2">
          <div>
            <code class="bg-gray-100 text-rappi px-2 py-0.5 rounded text-[11px] font-bold">${f.field_id}</code>
            <span class="ml-1 text-[10px] font-bold ${req ? 'text-red-500' : 'text-gray-400'}">${req ? 'REQ' : 'OPT'}</span>
          </div>
          ${canEdit ? `
          <div class="flex gap-0.5">
            <button onclick="editField(${i})" class="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition"><i class="fa-solid fa-pen text-[10px]"></i></button>
