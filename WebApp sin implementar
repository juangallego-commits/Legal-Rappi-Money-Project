function loadAdminFields() {
  const loading = document.getElementById('fieldsLoading');
  const grid = document.getElementById('fieldsGrid');
  const empty = document.getElementById('fieldsEmpty');
  loading.classList.remove('hidden'); grid.classList.add('hidden'); empty.classList.add('hidden');

  google.script.run
    .withSuccessHandler(r => {
      const data = JSON.parse(r);
      loading.classList.add('hidden');
      if (data.status !== 'ok' || !data.fields || data.fields.length === 0) { empty.classList.remove('hidden'); adminFields = []; return; }

      const fc = document.getElementById('filterFieldCountry').value;
      const ft = document.getElementById('filterFieldType').value;
      let filtered = data.fields;
      if (fc !== 'ALL') filtered = filtered.filter(f => f.country_code === 'ALL' || f.country_code === fc);
      if (ft !== 'ALL') filtered = filtered.filter(f => f.campaign_type === 'ALL' || f.campaign_type === ft);
      adminFields = data.fields;

      if (filtered.length === 0) { empty.classList.remove('hidden'); return; }
      grid.classList.remove('hidden');
      _renderFields(filtered, grid);
    })
    .withFailureHandler(() => { loading.classList.add('hidden'); empty.classList.remove('hidden'); })
    .adminGetFields();
}

