function loadFolders() {
  const loading = document.getElementById('foldersLoading');
  const tree = document.getElementById('foldersTree');
  const empty = document.getElementById('foldersEmpty');
  const rootLink = document.getElementById('folderRootLink');
  loading.classList.remove('hidden'); tree.classList.add('hidden'); empty.classList.add('hidden'); rootLink.classList.add('hidden');

  google.script.run
    .withSuccessHandler(r => {
      const data = JSON.parse(r);
      loading.classList.add('hidden');
      if (data.status !== 'ok' || !data.folders || data.folders.length === 0) { empty.classList.remove('hidden'); return; }

      if (data.rootUrl) {
        rootLink.href = data.rootUrl;
        rootLink.classList.remove('hidden');
      }

      tree.classList.remove('hidden');
      tree.innerHTML = data.folders
        .sort((a,b) => a.name.localeCompare(b.name))
        .map(cf => {
          const code = cf.name.split('_')[0];
          const flag = FLAG_MAP[code] || '📁';
          const countryName = cf.name.split('_').slice(1).join('_') || cf.name;
          const isSpecial = cf.name.startsWith('_');

          let subsHtml = cf.subFolders.map(sf => {
            const typeIcon = sf.name === 'Cashback' ? '💰' : (sf.name === 'Concurso' ? '🏆' : '📁');
            const filesHtml = sf.files.map(f =>
              `<div class="folder-file flex items-center gap-2 mt-1">
                <i class="fa-solid fa-file-lines text-blue-500 text-xs"></i>
                <a href="${f.url}" target="_blank" class="text-xs text-blue-600 hover:underline font-medium truncate">${f.name}</a>
              </div>`
            ).join('');
            return `
              <div class="ml-6 mt-2">
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <span>${typeIcon}</span>
                  <span class="font-semibold">${sf.name}</span>
                  <span class="text-[10px] text-gray-400">(${sf.files.length} archivos)</span>
                </div>
                ${filesHtml}
              </div>
            `;
          }).join('');

          return `
            <div class="folder-item" style="animation: fadeIn .3s ease;">
              <div class="flex items-center gap-2">
                <span class="text-xl">${isSpecial ? '📦' : flag}</span>
                <span class="font-bold text-gray-900">${isSpecial ? cf.name : countryName}</span>
                <span class="text-[10px] text-gray-400">${cf.subFolders.length} subcarpetas</span>
              </div>
              ${subsHtml}
            </div>
          `;
        }).join('');
    })
    .withFailureHandler(() => { loading.classList.add('hidden'); empty.classList.remove('hidden'); })
    .adminGetFolderStructure();
}

