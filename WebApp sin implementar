    <div class="tour-progress" id="tourProgress">1 de 5</div>
    <div class="tour-actions">
      <button class="tour-skip" onclick="endTour()">Saltar tour</button>
      <button class="btn-primary" id="tourNextBtn" onclick="nextTourStep()" style="padding:8px 20px;font-size:13px;">Siguiente <i class="fa-solid fa-arrow-right"></i></button>
    </div>
  </div>
</div>

<script>
  // ===== STATE =====  
  let currentStep = 1;  
  let selectedType = '';  
  let respChecks = [false, false, false];  
  let tourStep = 0;  
  let chatVisible = false;  
  let selectedCountry = 'CO';

  const allPages = ['landingPage','actionPage','generalTCPage','modifyPage','promoPage','formPage', 'adminPage'];

  document.addEventListener('DOMContentLoaded', function() {
    google.script.run.withSuccessHandler(function(resStr) {
      try {
        var res = JSON.parse(resStr);
        // Si el usuario es al menos viewer/editor/admin, mostramos el botón
        if (res.status === 'ok' && res.permissions && res.permissions.canViewAdmin) {
          document.getElementById('btnNavAdmin').classList.remove('hidden');
        }
      } catch(e) {}
    }).adminGetCurrentUser();
  });

  // ===== PAGE NAV =====  
  function showPage(id) {

  // ===== PAGE NAV =====
  function showPage(id) {
    allPages.forEach(p => document.getElementById(p).classList.add('hidden'));
    document.getElementById(id).classList.remove('hidden');
    window.scrollTo(0, 0);
    document.getElementById(id).querySelectorAll('.anim-up').forEach(el => {
      el.style.animation = 'none'; el.offsetHeight; el.style.animation = '';
    });
  }
  function hideModal(id) { document.getElementById(id).classList.add('hidden'); }
  function showModal(id) { document.getElementById(id).classList.remove('hidden'); }

  // ===== LANDING FLOW =====
  function showResponsibilityModal() {
    respChecks = [false, false, false];
    document.querySelectorAll('.resp-check').forEach(c => c.classList.remove('checked'));
    document.getElementById('btnAcceptResp').disabled = true;
    showModal('responsibilityModal');
  }
  function toggleResp(idx) {
    respChecks[idx] = !respChecks[idx];
    document.querySelectorAll('.resp-check')[idx].classList.toggle('checked', respChecks[idx]);
    document.getElementById('btnAcceptResp').disabled = !respChecks.every(Boolean);
  }
  function acceptResponsibility() {
    hideModal('responsibilityModal');
    showModal('countryModal');
  }
  function selectCountry(code) {
    selectedCountry = code;
    document.getElementById('hCountryCode').value = code;
    hideModal('countryModal');
    showPage('actionPage');
    if (!localStorage.getItem('rmTourDone')) { setTimeout(()=> startTour(), 500); }
  }
  function backToLanding() { showPage('landingPage'); }
  function confirmBack() {
    if (confirm('¿Volver? Tu progreso no guardado se perderá.')) showPage('actionPage');
  }

  // ===== ACTION SELECTOR =====
  function showPromoSelector() { showPage('promoPage'); }
  function showGeneralTC() { showPage('generalTCPage'); }
  function showModifyFlow() { showPage('modifyPage'); }

  function copyTCLink() {
    const link = document.getElementById('tcGenLink').value;
    navigator.clipboard.writeText(link).then(() => {
      const btn = document.querySelector('.tc-link-input button');
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Copiado!';
      setTimeout(() => { btn.innerHTML = '<i class="fa-solid fa-copy"></i> Copiar'; }, 2000);
    });
  }

  // ===== MODIFY FLOW =====
  function toggleChangeChip(el) {
    el.classList.toggle('selected');
    updateModifyFields();
  }
  function updateModifyFields() {
    const selected = document.querySelectorAll('.change-chip.selected');
    const container = document.getElementById('modifyNewValues');
    container.style.display = selected.length > 0 ? 'block' : 'none';
    const map = { dates:'modifyDateFields', budget:'modifyBudgetField', territory:'modifyTerritoryField', cap:'modifyCapField', percentage:'modifyPctField' };
    Object.values(map).forEach(id => document.getElementById(id).style.display = 'none');
    selected.forEach(chip => {
      const field = map[chip.dataset.change];
      if (field) document.getElementById(field).style.display = 'block';
    });
  }
  function submitModify() {
    const link = document.getElementById('fModifyLink').value.trim();
    const campaign = document.getElementById('fModifyCampaign').value.trim();
    if (!link || !campaign) { alert('Completa el link y nombre de campaña.'); return; }
    const selected = document.querySelectorAll('.change-chip.selected');
    if (selected.length === 0) { alert('Selecciona al menos un cambio.'); return; }

    const changes = [];
    selected.forEach(chip => changes.push(chip.dataset.change));

    const payload = {
      action: 'modify',
      originalDocLink: link,
      campaignName: campaign,
      changes: changes,
      newEndDate: document.getElementById('fModifyEndDate') ? document.getElementById('fModifyEndDate').value : '',
      newEndTime: document.getElementById('fModifyEndTime') ? document.getElementById('fModifyEndTime').value : '23:59',
      newBudget: document.getElementById('fModifyBudget') ? document.getElementById('fModifyBudget').value : '',
      newTerritory: document.getElementById('fModifyTerritory') ? document.getElementById('fModifyTerritory').value : '',
      newCap: document.getElementById('fModifyCap') ? document.getElementById('fModifyCap').value : '',
      newPct: document.getElementById('fModifyPct') ? document.getElementById('fModifyPct').value : '',
      reason: document.getElementById('fModifyReason') ? document.getElementById('fModifyReason').value : ''
    };

    showModal('loadingOverlay');
    // TODO: Connect to processModifyPayload when backend is ready
    setTimeout(function() {
      hideModal('loadingOverlay');
      alert('✅ Funcionalidad de modificación en desarrollo. El payload está listo:\n' + JSON.stringify(changes));
    }, 1500);
  }

  // ===== WIZARD =====
  function startWizard(type) {
    selectedType = type;
    document.getElementById('cashbackFields').classList.toggle('hidden', type !== 'Cashback');
    document.getElementById('concursoFields').classList.toggle('hidden', type !== 'Concurso');
    document.getElementById('step3Title').textContent = type === 'Cashback' ? 'Variables de Cashback' : 'Variables del Concurso';
    document.getElementById('step3Desc').textContent = type === 'Cashback' ? '%, topes, presupuesto' : 'Organizador, premios';
    document.getElementById('stepDesc3').textContent = type === 'Cashback' ? '%, topes, presupuesto' : 'Organizador, premios';
    currentStep = 1;
    showPage('formPage');
    loadDraft();
    renderStep();
  }

  function goToStep(n) {
    if (n > currentStep && !canProceed(currentStep)) return;
    currentStep = n;
    renderStep();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function renderStep() {
    document.querySelectorAll('.wizard-step').forEach(function(s) { s.classList.add('hidden'); });
    document.getElementById('wizStep' + currentStep).classList.remove('hidden');
    document.querySelectorAll('.step-item').forEach(function(item) {
      var step = parseInt(item.dataset.step);
      item.classList.remove('active', 'completed');
      if (step < currentStep) item.classList.add('completed');
      if (step === currentStep) item.classList.add('active');
    });
    updateProgress();
    document.getElementById('wizStep' + currentStep).querySelectorAll('.anim-up').forEach(function(el) {
      el.style.animation = 'none'; el.offsetHeight; el.style.animation = '';
    });
  }

  function canProceed(step) {
    switch(step) {
      case 1:
        var email = document.getElementById('fEmail').value.trim();
        var shop = document.getElementById('fShop').value.trim();
        var terr = document.getElementById('fTerritory').value.trim();
        if (!email.endsWith('@rappi.com')) { alert('Ingresa un email @rappi.com válido.'); return false; }
        if (!shop || !terr) { alert('Completa tienda y territorio.'); return false; }
        return true;
      case 2:
        var sd = document.getElementById('fStartDate').value;
        var ed = document.getElementById('fEndDate').value;
        if (!sd || !ed) { alert('Completa fechas de inicio y fin.'); return false; }
        if (new Date(ed) < new Date(sd)) { alert('Fecha fin debe ser >= fecha inicio.'); return false; }
        return true;
      case 3:
        if (selectedType === 'Cashback') {
          var p = parseFloat(document.getElementById('fPct').value);
          var c = parseFloat(document.getElementById('fCap').value);
          var b = parseFloat(document.getElementById('fBudget').value);
          if (!p||p<1||p>100||!c||c<1000||!b||b<10000) { alert('Revisa los valores de cashback.'); return false; }
        } else {
          if (!document.getElementById('fOrgName').value.trim() || !document.getElementById('fOrgPhone').value.trim() || !document.getElementById('fOrgEmail').value.trim() || !document.getElementById('fAnnouncement').value) { alert('Completa todos los campos del organizador.'); return false; }
        }
        return true;
      default: return true;
    }
  }

  // ===== VALIDATION =====
  function validateEmail() {
    var input = document.getElementById('fEmail');
    var error = document.getElementById('emailError');
    var val = input.value.trim();
    if (val && !val.endsWith('@rappi.com')) { input.classList.add('error'); error.classList.add('show'); return false; }
    input.classList.remove('error'); error.classList.remove('show');
    if (val.endsWith('@rappi.com')) input.classList.add('valid');
    return true;
  }
  function validateDates() {
    var sd = document.getElementById('fStartDate').value;
    var ed = document.getElementById('fEndDate').value;
    var error = document.getElementById('dateError');
    var endInput = document.getElementById('fEndDate');
    if (sd && ed && new Date(ed) < new Date(sd)) { endInput.classList.add('error'); error.classList.add('show'); return false; }
    endInput.classList.remove('error'); error.classList.remove('show');
    return true;
  }

  function onFieldChange() {
    saveDraft();
    var email = document.getElementById('fEmail').value.trim();
    var shop = document.getElementById('fShop').value.trim();
    var terr = document.getElementById('fTerritory').value.trim();
    document.getElementById('btnNext1').disabled = !(email.endsWith('@rappi.com') && shop && terr);

    var sd = document.getElementById('fStartDate').value;
    var ed = document.getElementById('fEndDate').value;
    document.getElementById('btnNext2').disabled = !(sd && ed && new Date(ed) >= new Date(sd));

    var s3ok = false;
    if (selectedType === 'Cashback') {
      var p=parseFloat(document.getElementById('fPct').value), c=parseFloat(document.getElementById('fCap').value), b=parseFloat(document.getElementById('fBudget').value);
      s3ok = p>=1&&p<=100&&c>=1000&&b>=10000;
    } else if (selectedType === 'Concurso') {
      s3ok = !!document.getElementById('fOrgName').value.trim()&&!!document.getElementById('fOrgPhone').value.trim()&&!!document.getElementById('fOrgEmail').value.trim()&&!!document.getElementById('fAnnouncement').value;
    }
    document.getElementById('btnNext3').disabled = !s3ok;
    document.getElementById('btnGenerate').disabled = !(document.getElementById('btnNext1').disabled === false && document.getElementById('btnNext2').disabled === false && !document.getElementById('btnNext3').disabled);
    updateProgress();
  }

  function updateProgress() {
    var completed = 0;
    var email = document.getElementById('fEmail').value.trim();
    var shop = document.getElementById('fShop').value.trim();
    var terr = document.getElementById('fTerritory').value.trim();
    if (email.endsWith('@rappi.com') && shop && terr) completed++;
    var sd = document.getElementById('fStartDate').value;
    var ed = document.getElementById('fEndDate').value;
    if (sd && ed && new Date(ed) >= new Date(sd)) completed++;
    var s3ok = false;
    if (selectedType === 'Cashback') {
      var p=parseFloat(document.getElementById('fPct').value), c=parseFloat(document.getElementById('fCap').value), b=parseFloat(document.getElementById('fBudget').value);
      s3ok = p>=1&&p<=100&&c>=1000&&b>=10000;
    } else if (selectedType === 'Concurso') {
      s3ok = !!document.getElementById('fOrgName').value.trim()&&!!document.getElementById('fOrgPhone').value.trim()&&!!document.getElementById('fOrgEmail').value.trim()&&!!document.getElementById('fAnnouncement').value;
    }
    if (s3ok) completed++;
    completed++; // step 4 always counts (optional)
    var pct = completed / 4;
    var circle = document.getElementById('progressCircle');
    if (circle) circle.style.strokeDashoffset = 113 - (113 * pct);
    var label = document.getElementById('progressLabel');
    if (label) label.innerHTML = '<strong>' + completed + ' de 4</strong> pasos';
  }

  // ===== TOGGLE HELPERS =====
  function togglePrizeFields() {
    var isCredits = document.querySelector('input[name="prizeType"]:checked');
    isCredits = isCredits ? isCredits.value === 'credits' : true;
    document.getElementById('creditsPrizeFields').style.display = isCredits ? 'block' : 'none';
    document.getElementById('physicalPrizeFields').style.display = isCredits ? 'none' : 'block';
    if (isCredits) {
      document.getElementById('dataTransferSection').style.display = 'none';
      document.getElementById('hDataTransferConfirmed').value = 'false';
    }
  }
  function toggleDataTransfer() {
    var isOrganizer = document.querySelector('input[name="deliveryBy"]:checked');
    isOrganizer = isOrganizer ? isOrganizer.value === 'organizer' : false;
    document.getElementById('dataTransferSection').style.display = isOrganizer ? 'block' : 'none';
    if (!isOrganizer) document.getElementById('hDataTransferConfirmed').value = 'false';
  }
  function toggleAdvConfig(el) {
    el.classList.toggle('open');
    var body = el.nextElementSibling;
    body.classList.toggle('open');
  }
  function toggleValidityFields() {
    var type = document.getElementById('fValidityType').value;
    document.getElementById('validityDaysField').style.display = type.indexOf('días') >= 0 ? 'block' : 'none';
    document.getElementById('validityDatesField').style.display = type.indexOf('fechas') >= 0 ? 'flex' : 'none';
  }

  // ========================================
  // SUBMIT — REAL BACKEND CONNECTION
  // ========================================
  function submitForm() {
    if (!canProceed(1)||!canProceed(2)||!canProceed(3)) return;

    var prizeTypeEl = document.querySelector('input[name="prizeType"]:checked');
    var prizeType = prizeTypeEl ? prizeTypeEl.value : 'credits';
    var deliveryEl = document.querySelector('input[name="deliveryBy"]:checked');
    var deliveryBy = deliveryEl ? deliveryEl.value : 'rappi';

    // Gather special conditions from chips
    var conditions = [];
    document.querySelectorAll('#condChips .cond-chip.selected').forEach(function(chip) {
      conditions.push(chip.dataset.cond);
    });

    // Build prizes string for Concurso
    var prizes = '';
    if (selectedType === 'Concurso') {
      if (prizeType === 'credits') {
        prizes = (document.getElementById('fCreditsAmount').value || '0') + ' Créditos Rappi';
      } else {
        prizes = document.getElementById('fPhysicalPrize').value || '';
      }
    }

    var payload = {
      countryCode: document.getElementById('hCountryCode').value,
      currencyCode: document.getElementById('hCurrencyCode').value,
      currencySymbol: document.getElementById('hCurrencySymbol').value,
      userEmail: document.getElementById('fEmail').value.trim(),
      dynamicType: selectedType === 'Concurso' ? 'Concurso Mayor Comprador' : selectedType,
      campaignName: document.getElementById('fCampaignName').value.trim(),
      shopName: document.getElementById('fShop').value.trim(),
      territory: document.getElementById('fTerritory').value.trim(),
      startDate: document.getElementById('fStartDate').value,
      startTime: document.getElementById('fStartTime').value || '00:00',
      endDate: document.getElementById('fEndDate').value,
      endTime: document.getElementById('fEndTime').value || '23:59',
      extraEmails: document.getElementById('fExtraEmails').value.trim(),
      specialConditions: conditions.join('; '),
      maxOrders: document.getElementById('fMaxOrders').value || '1',
      paymentMethods: document.getElementById('fPayment').value,
      userSegment: document.getElementById('fSegment').value,
      minPurchase: document.getElementById('fMinPurchase').value || '',
      cashbackPct: document.getElementById('fPct') ? document.getElementById('fPct').value : '',
      cap: document.getElementById('fCap') ? document.getElementById('fCap').value : '',
      budget: document.getElementById('fBudget') ? document.getElementById('fBudget').value : '',
      redemptionPlace: document.getElementById('fRedemption') ? document.getElementById('fRedemption').value : '',
      loadType: document.getElementById('fLoadType') ? document.getElementById('fLoadType').value : 'Inmediatamente (Al finalizar la orden)',
      loadDate: document.getElementById('fLoadDate') ? document.getElementById('fLoadDate').value : '',
      validityType: document.getElementById('fValidityType') ? document.getElementById('fValidityType').value : 'Por días calendario (Duración)',
      validityDays: document.getElementById('fValidityDays') ? document.getElementById('fValidityDays').value : '30',
      redemptionStart: document.getElementById('fRedemptionStart') ? document.getElementById('fRedemptionStart').value : '',
      redemptionEnd: document.getElementById('fRedemptionEnd') ? document.getElementById('fRedemptionEnd').value : '',
      organizerLegalName: document.getElementById('fOrgName') ? document.getElementById('fOrgName').value : '',
      organizerPhone: document.getElementById('fOrgPhone') ? document.getElementById('fOrgPhone').value : '',
      organizerEmail: document.getElementById('fOrgEmail') ? document.getElementById('fOrgEmail').value : '',
      winnerCriteria: document.getElementById('fCriteria') ? document.getElementById('fCriteria').value : '',
      numberOfWinners: document.getElementById('fWinners') ? document.getElementById('fWinners').value : '1',
      verticals: document.getElementById('fVerticals') ? document.getElementById('fVerticals').value : 'Restaurantes',
      participatingProducts: document.getElementById('fProducts') ? document.getElementById('fProducts').value : '',
      prizeType: prizeType,
      creditsAmount: document.getElementById('fCreditsAmount') ? document.getElementById('fCreditsAmount').value : '',
      creditLoadDays: document.getElementById('fCreditLoadDays') ? document.getElementById('fCreditLoadDays').value : '5',
      creditsValidityDays: document.getElementById('fCreditsValidityDays') ? document.getElementById('fCreditsValidityDays').value : '30',
      creditsRedemptionPlace: document.getElementById('fCreditsRedemption') ? document.getElementById('fCreditsRedemption').value : '',
      physicalPrizeDescription: document.getElementById('fPhysicalPrize') ? document.getElementById('fPhysicalPrize').value : '',
      prizeDeliveryBy: deliveryBy,
      dataTransferConfirmed: document.getElementById('hDataTransferConfirmed').value,
      minParticipation: document.getElementById('fMinParticipation') ? document.getElementById('fMinParticipation').value : '',
      prizes: prizes,
      announcementDate: document.getElementById('fAnnouncement') ? document.getElementById('fAnnouncement').value : ''
    };

    showModal('loadingOverlay');
    var btn = document.getElementById('btnGenerate');
    btn.disabled = true;

    google.script.run
      .withSuccessHandler(function(response) {
        var res = JSON.parse(response);
        hideModal('loadingOverlay');
        if (res.status === 'success') {
          document.getElementById('docLink').href = res.docUrl;
          showModal('successModal');
          addToHistory(res.docName, res.docUrl, selectedType, payload.shopName);
          clearDraft();
        } else {
          alert('Error: ' + res.message);
          btn.disabled = false;
        }
      })
      .withFailureHandler(function(error) {
        hideModal('loadingOverlay');
        alert('Error del servidor: ' + error);
        btn.disabled = false;
      })
      .processWebPayload(JSON.stringify(payload));
  }

  // ===== DRAFT AUTOSAVE =====
  function saveDraft() {
    try {
      var draft = {
        type: selectedType,
        email: document.getElementById('fEmail').value,
        shop: document.getElementById('fShop').value,
        territory: document.getElementById('fTerritory').value,
        campaignName: document.getElementById('fCampaignName').value,
        startDate: document.getElementById('fStartDate').value,
        endDate: document.getElementById('fEndDate').value,
        startTime: document.getElementById('fStartTime').value,
        endTime: document.getElementById('fEndTime').value
      };
      if (selectedType === 'Cashback') {
        draft.pct = document.getElementById('fPct').value;
        draft.cap = document.getElementById('fCap').value;
        draft.budget = document.getElementById('fBudget').value;
      }
      localStorage.setItem('rmDraft', JSON.stringify(draft));
    } catch(e) {}
  }
  function loadDraft() {
    try {
      var raw = localStorage.getItem('rmDraft');
      if (!raw) return;
      var d = JSON.parse(raw);
      if (d.type !== selectedType) return;
      if (d.email) document.getElementById('fEmail').value = d.email;
      if (d.shop) document.getElementById('fShop').value = d.shop;
      if (d.territory) document.getElementById('fTerritory').value = d.territory;
      if (d.campaignName) document.getElementById('fCampaignName').value = d.campaignName;
      if (d.startDate) document.getElementById('fStartDate').value = d.startDate;
      if (d.endDate) document.getElementById('fEndDate').value = d.endDate;
      if (d.startTime) document.getElementById('fStartTime').value = d.startTime;
      if (d.endTime) document.getElementById('fEndTime').value = d.endTime;
      if (selectedType === 'Cashback') {
        if (d.pct) document.getElementById('fPct').value = d.pct;
        if (d.cap) document.getElementById('fCap').value = d.cap;
        if (d.budget) document.getElementById('fBudget').value = d.budget;
      }
      onFieldChange();
    } catch(e) {}
  }
  function clearDraft() { localStorage.removeItem('rmDraft'); }

  // ===== HISTORY =====
  function addToHistory(name, url, type, shop) {
    try {
      var history = JSON.parse(localStorage.getItem('rmHistory') || '[]');
      history.unshift({ name: name, url: url, type: type, shop: shop, date: new Date().toISOString() });
      if (history.length > 20) history = history.slice(0, 20);
      localStorage.setItem('rmHistory', JSON.stringify(history));
    } catch(e) {}
  }

  // ===== DEMO =====
  var demoIdx = 0;
  function fillDemo() {
    var demos = [
      { type:'Cashback', shop:'Hamburguesas El Corral', territory:'Nacional', pct:20, cap:20000, budget:1000000 },
      { type:'Cashback', shop:'D1 Express', territory:'Bogotá, Medellín', pct:15, cap:10000, budget:500000 },
      { type:'Concurso', shop:'Coca-Cola FEMSA', territory:'Nacional', org:'INDUSTRIA NACIONAL DE GASEOSAS S.A.S.', phone:'018000912580', email:'pqr@coca-cola.com', winners:3, credits:100000 }
    ];
    var d = demos[demoIdx % demos.length]; demoIdx++;
    selectedType = d.type;
    document.getElementById('cashbackFields').classList.toggle('hidden', d.type !== 'Cashback');
    document.getElementById('concursoFields').classList.toggle('hidden', d.type !== 'Concurso');
    document.getElementById('step3Title').textContent = d.type === 'Cashback' ? 'Variables de Cashback' : 'Variables del Concurso';
    document.getElementById('fEmail').value = 'test@rappi.com';
    document.getElementById('fShop').value = d.shop;
    document.getElementById('fTerritory').value = d.territory;
    var today = new Date().toISOString().split('T')[0];
    var nextMonth = new Date(Date.now() + 30*86400000).toISOString().split('T')[0];
    document.getElementById('fStartDate').value = today;
    document.getElementById('fEndDate').value = nextMonth;
    if (d.type === 'Cashback') {
      document.getElementById('fPct').value = d.pct;
      document.getElementById('fCap').value = d.cap;
      document.getElementById('fBudget').value = d.budget;
    } else {
      document.getElementById('fOrgName').value = d.org;
      document.getElementById('fOrgPhone').value = d.phone;
      document.getElementById('fOrgEmail').value = d.email;
      document.getElementById('fWinners').value = d.winners;
      document.getElementById('fCreditsAmount').value = d.credits;
      document.getElementById('fAnnouncement').value = nextMonth;
    }
    onFieldChange();
    alert('Demo "' + d.type + '" cargado: ' + d.shop + '. Navega los pasos para revisar.');
  }

  // ===== CHATBOT (GEMINI AI) =====
  function toggleChat() {
    chatVisible = !chatVisible;
    document.getElementById('chatPanel').classList.toggle('hidden', !chatVisible);
    document.getElementById('chatFab').style.display = chatVisible ? 'none' : 'flex';
    if (chatVisible) { setTimeout(function() { document.getElementById('chatInput').focus(); }, 100); }
  }
  function askQuick(q) {
    addChatMsg(q, 'user');
    document.getElementById('chatQuickActions').style.display = 'none';
    sendToGemini(q);
  }
  function sendChat() {
    var input = document.getElementById('chatInput');
    var q = input.value.trim();
    if (!q) return;
    addChatMsg(q, 'user');
    input.value = '';
    input.disabled = true;
    document.getElementById('chatQuickActions').style.display = 'none';
    sendToGemini(q);
  }
  function sendToGemini(msg) {
    var loadingId = 'loading-' + Date.now();
    var body = document.getElementById('chatBody');
    var loadDiv = document.createElement('div');
    loadDiv.id = loadingId;
    loadDiv.className = 'chat-msg bot';
    loadDiv.style.opacity = '0.6';
    loadDiv.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin" style="margin-right:6px;"></i> Pensando...';
    body.appendChild(loadDiv);
    body.scrollTop = body.scrollHeight;

    google.script.run
      .withSuccessHandler(function(response) {
        var el = document.getElementById(loadingId);
        if (el) el.remove();
        var formatted = response.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>');
        addChatMsg(formatted, 'bot');
        document.getElementById('chatInput').disabled = false;
        document.getElementById('chatInput').focus();
      })
      .withFailureHandler(function(error) {
        var el = document.getElementById(loadingId);
        if (el) el.remove();
        addChatMsg('Error de conexión. Intenta de nuevo.', 'bot');
        document.getElementById('chatInput').disabled = false;
      })
      .askGemini(msg);
  }
  function addChatMsg(text, type) {
    var body = document.getElementById('chatBody');
    var msg = document.createElement('div');
    msg.className = 'chat-msg ' + type;
    if (type === 'bot') { msg.innerHTML = text; } else { msg.textContent = text; }
    body.appendChild(msg);
    body.scrollTop = body.scrollHeight;
  }

  // ===== ONBOARDING TOUR =====
  var tourSteps = [
    { title:'Bienvenido a RappiMind', text:'Esta herramienta te permite generar Términos y Condiciones para campañas de marketing en LATAM. Te voy a explicar las opciones principales.', target:null },
    { title:'Crear Campaña Nueva', text:'Usa esta opción para Cashback o Concursos. Te guiará paso a paso por un wizard con validación en tiempo real.', target:null },
    { title:'Modificar Campaña', text:'Si una campaña necesita cambios (ej: extender fechas), esta opción genera una constancia de modificación transparente.', target:null },
    { title:'T&C Generales', text:'Para descuentos y cupones, ya existen T&C publicados. Aquí obtienes el link directamente sin generar nada nuevo.', target:null },
    { title:'Asistente Inteligente', text:'El botón naranja flotante abre el asistente con Gemini AI. Tiene respuestas rápidas y también puedes hacer preguntas libres.', target:null }
  ];

  function startTour() {
    tourStep = 0;
    document.getElementById('tourOverlay').classList.remove('hidden');
    renderTourStep();
  }
  function endTour() {
    document.getElementById('tourOverlay').classList.add('hidden');
    localStorage.setItem('rmTourDone', '1');
  }
  function nextTourStep() {
    tourStep++;
    if (tourStep >= tourSteps.length) { endTour(); return; }
    renderTourStep();
  }
  function renderTourStep() {
    var s = tourSteps[tourStep];
    document.getElementById('tourTitle').innerHTML = '<svg width="18" height="18" style="vertical-align:middle;"><use href="#brain-icon"/></svg> ' + s.title;
    document.getElementById('tourText').textContent = s.text;
    document.getElementById('tourProgress').textContent = (tourStep + 1) + ' de ' + tourSteps.length;
    document.getElementById('tourNextBtn').textContent = tourStep === tourSteps.length - 1 ? 'Empezar!' : 'Siguiente';
    var tt = document.getElementById('tourTooltip');
    tt.style.top = '50%'; tt.style.left = '50%'; tt.style.transform = 'translate(-50%, -50%)';
    tt.style.animation = 'none'; tt.offsetHeight; tt.style.animation = 'slideDown 0.3s cubic-bezier(0.16,1,0.3,1)';
  }

  function showHelp() { startTour(); }

  // ===== LOAD TYPE TOGGLE =====
  document.addEventListener('DOMContentLoaded', function() {
    var lt = document.getElementById('fLoadType');
    if (lt) {
      lt.addEventListener('change', function() {
        document.getElementById('loadDateField').style.display = this.value === 'Fecha específica' ? 'block' : 'none';
      });
    }
  });
</script>

