function saveTemplate(event) {
  event.preventDefault();
  const editIndex = parseInt(document.getElementById('tpl_editIndex').value);
  const cc = document.getElementById('tpl_country').value;
  const currCode = document.getElementById('tpl_currency').value;

  const d = {
    country_code: cc,
    country_name: COUNTRY_NAMES[cc] || cc,
    campaign_type: document.getElementById('tpl_type').value,
    template_doc_id: document.getElementById('tpl_docId').value.trim(),
    version: document.getElementById('tpl_version').value || '1.0',
    currency_code: currCode,
    currency_symbol: CURRENCY_SYMBOLS[currCode] || '$',
    notes: document.getElementById('tpl_notes').value
  };

  if (currentUser.permissions.canApproveTemplates) {
    d.status = document.getElementById('tpl_status').value;
  }

  if (d.template_doc_id.length < 10) { alert('⚠️ El Doc ID parece muy corto.'); return; }

  const btn = event.target.querySelector('[type="submit"]');
  btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner animate-spin mr-1.5"></i>Guardando...';

  google.script.run
    .withSuccessHandler(r => {
      const res = JSON.parse(r);
      btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-save mr-1.5"></i>Guardar';
      if (res.status === 'ok') {
        hideAddTemplateModal(); loadAdminTemplates();
        alert('✅ ' + (res.message || 'Guardado'));
      } else { alert('❌ ' + res.message); }
    })
    .withFailureHandler(e => { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-save mr-1.5"></i>Guardar'; alert('❌ ' + e); })
    .adminSaveTemplate(JSON.stringify(d), editIndex);
}

