function twCallBackend(action, data) {  
  return new Promise(function(resolve, reject) {  
    var onSuccess \= function(res) {  
      if (typeof res \=== 'string') { try { resolve(JSON.parse(res)); } catch(e) { resolve({ success:true, data:res }); } }  
      else { resolve(res || { success:true }); }  
    };  
    var onFailure \= function(err) { reject(new Error(err.message || 'Error en el servidor')); };  
    var api \= google.script.run.withSuccessHandler(onSuccess).withFailureHandler(onFailure);  
    if (action \=== 'tw\_analyzeText') {  
      if (typeof api.analyzeTextForPlaceholders \!== 'function') return reject(new Error("analyzeTextForPlaceholders no disponible. Usa /dev URL."));  
      api.analyzeTextForPlaceholders(data);  
    } else if (action \=== 'tw\_fetchDocContent') {  
      if (typeof api.fetchGoogleDocContent \!== 'function') return reject(new Error("fetchGoogleDocContent no disponible."));  
      api.fetchGoogleDocContent(data);  
    } else if (action \=== 'tw\_createTemplate') {  
      if (typeof api.createTemplateFromWizard \!== 'function') return reject(new Error("createTemplateFromWizard no disponible."));  
      api.createTemplateFromWizard(data);  
    } else {  
      reject(new Error("Acción no reconocida: " \+ action));  
    }  
  });  
}

