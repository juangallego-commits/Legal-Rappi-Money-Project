/**
 * Marca un campo como valido/invalido visualmente.
 * Requiere que el input este dentro de un div con clase .field
 */
function toggleInputState(input, isValid) {
  if (!input) return;
  var field = input.closest('.field') || input.parentElement;
  if (!field) return;
  field.classList.remove('field-valid', 'field-error-active');
  if (input.value.trim() === '') return; // No marcar campos vacios
  field.classList.add(isValid ? 'field-valid' : 'field-error-active');
}

