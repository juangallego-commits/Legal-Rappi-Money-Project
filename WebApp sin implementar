  return isValid;
}

/** Valida emails adicionales (separados por coma) */
function validateExtraEmails(input) {
  if (!input) input = document.getElementById('fExtraEmails');
  if (!input) return true;
  var value = input.value.trim();
  if (value === '') { toggleInputState(input, true); return true; }
  var emails = value.split(',').map(function(e) { return e.trim(); });
  var isValid = emails.every(function(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  });
  toggleInputState(input, isValid);
  return isValid;
}

/** Sanitiza HTML para prevenir XSS */
function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
