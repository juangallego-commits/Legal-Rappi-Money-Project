    try {  
      var h \= localStorage.getItem('rmHistory');  
      return h ? JSON.parse(h) : \[\];  
    } catch(e) { return \[\]; }  
  }

  function renderHistory() {  
    var history \= getHistory();  
    var listEl \= document.getElementById('historyList');  
    var emptyEl \= document.getElementById('historyEmpty');  
    if (\!listEl) return;

    if (history.length \=== 0\) {  
      listEl.innerHTML \= '';  
      listEl.classList.add('hidden');  
      emptyEl.classList.remove('hidden');  
      return;  
    }

    listEl.classList.remove('hidden');  
    emptyEl.classList.add('hidden');

    listEl.innerHTML \= history.map(function(item) {  
      var d \= new Date(item.date);  
      var dateStr \= d.toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' });  
      var timeStr \= d.toLocaleTimeString('es-CO', { hour:'2-digit', minute:'2-digit' });  
      var icon \= item.type \=== 'Cashback' ? '💰' : '🏆';

      return '\<a href="' \+ (item.url||'\#') \+ '" target="\_blank" class="history-item"\>' \+  
        '\<div class="hi-icon"\>' \+ icon \+ '\</div\>' \+  
        '\<div class="hi-info"\>\<div class="hi-shop"\>' \+ (item.shop||'Sin tienda') \+ '\</div\>\<div class="hi-type"\>' \+ (item.type||'') \+ '\</div\>\</div\>' \+  
        '\<div class="hi-date"\>\<div class="hi-date-str"\>' \+ dateStr \+ '\</div\>\<div class="hi-time-str"\>' \+ timeStr \+ '\</div\>\</div\>' \+  
      '\</a\>';  
    }).join('');  
  }

  function showHistoryModal() {  
    renderHistory();  
    showModal('historyModal');  
  }

  function clearHistory() {  
    if (confirm('¿Seguro que quieres eliminar el historial?')) {  
      localStorage.removeItem('rmHistory');  
      renderHistory();  
    }  
  }

  // \==========================================================  
  // PHASE 2: PREVIEW SYSTEM  
  // \==========================================================  
  function togglePreview() {  
    previewVisible \= \!previewVisible;  
    var drawer \= document.getElementById('previewDrawer');  
    var toggle \= document.getElementById('previewToggle');  
    if (previewVisible) {  
      drawer.classList.add('open');  
      toggle.classList.add('active');  
      updatePreview();  
    } else {  
      drawer.classList.remove('open');  
      toggle.classList.remove('active');  
    }  
  }

  function updatePreview() {  
    var el \= document.getElementById('previewContent');  
    if (\!el) return;

    var type \= selectedType;  
    if (\!type) {  
      el.innerHTML \= '\<p style="text-align:center;padding:40px 20px;color:var(--text-3);"\>' \+  
        '\<i class="fa-solid fa-file-lines" style="font-size:32px;display:block;margin-bottom:8px;"\>\</i\>' \+  
        'Selecciona un tipo de campaña para ver la vista previa\</p\>';  
      return;  
    }

