  function canProceed(step) {
  switch(step) {
    case 1:
      var email = document.getElementById('fEmail').value.trim();
      var shop = document.getElementById('fShop').value.trim();
      var terr = document.getElementById('fTerritory').value.trim();

      var emailOk = email.endsWith('@rappi.com') && email.indexOf('@') > 0;
      var shopOk = shop.length >= 3;
      var terrOk = terr.length >= 3;

      // Feedback visual inline
      toggleInputState(document.getElementById('fEmail'), emailOk);
      toggleInputState(document.getElementById('fShop'), shopOk);
      toggleInputState(document.getElementById('fTerritory'), terrOk);

      if (!emailOk) {
        alert('Ingresa un email @rappi.com valido.');
        document.getElementById('fEmail').focus();
        return false;
      }
      if (!shopOk) {
        alert('Ingresa el nombre de la tienda (min. 3 caracteres).');
        document.getElementById('fShop').focus();
        return false;
      }
      if (!terrOk) {
        alert('Ingresa el territorio (min. 3 caracteres).');
        document.getElementById('fTerritory').focus();
        return false;
      }

      // Validar extra emails si hay
      var extra = document.getElementById('fExtraEmails');
      if (extra && extra.value.trim() !== '') {
        if (!validateExtraEmails(extra)) {
          alert('Uno o mas emails adicionales tienen formato invalido.');
          extra.focus();
          return false;
        }
      }
      return true;

    case 2:
      var start = document.getElementById('fStartDate').value;
      var end = document.getElementById('fEndDate').value;
      if (!start || !end) {
        alert('Completa las fechas de inicio y fin.');
        return false;
      }
      if (new Date(end) < new Date(start)) {
        alert('La fecha de fin debe ser posterior a la de inicio.');
        toggleInputState(document.getElementById('fEndDate'), false);
        return false;
      }
      return true;

    case 3:
      if (selectedType === 'Cashback') {
        var pct = document.getElementById('fCashbackPct');
        var cap = document.getElementById('fCap');
        var budget = document.getElementById('fBudget');

        var pctVal = parseFloat(pct ? pct.value : 0);
        var capVal = parseFloat(cap ? cap.value : 0);
        var budgetVal = parseFloat(budget ? budget.value : 0);

        var pctOk = !isNaN(pctVal) && pctVal >= 1 && pctVal <= 100;
        var capOk = !isNaN(capVal) && capVal >= 1000;
        var budgetOk = !isNaN(budgetVal) && budgetVal >= 10000;

        if (pct) toggleInputState(pct, pctOk);
        if (cap) toggleInputState(cap, capOk);
        if (budget) toggleInputState(budget, budgetOk);

        if (!pctOk) {
          alert('Porcentaje de cashback debe estar entre 1 y 100.');
          if (pct) pct.focus();
          return false;
        }
        if (!capOk) {
          alert('Tope por usuario debe ser >= 1,000.');
          if (cap) cap.focus();
          return false;
        }
        if (!budgetOk) {
          alert('Presupuesto debe ser >= 10,000.');
          if (budget) budget.focus();
          return false;
        }
        return true;

      } else if (selectedType === 'Concurso') {
        var org = document.getElementById('fOrgName');
        var phone = document.getElementById('fOrgPhone');
        var orgEmail = document.getElementById('fOrgEmail');
        var winners = document.getElementById('fWinners');
        var announce = document.getElementById('fAnnouncement');

        if (org) toggleInputState(org, org.value.trim().length >= 3);
        if (phone) toggleInputState(phone, phone.value.trim().length >= 7);
        if (orgEmail) toggleInputState(orgEmail, orgEmail.value.includes('@'));

        if (!org || org.value.trim().length < 3) {
          alert('Ingresa la razon social del organizador.');
          if (org) org.focus();
          return false;
        }
        if (!phone || phone.value.trim().length < 7) {
          alert('Ingresa un telefono de contacto valido.');
          if (phone) phone.focus();
          return false;
        }
        if (!orgEmail || !orgEmail.value.includes('@')) {
          alert('Ingresa un email valido del organizador.');
          if (orgEmail) orgEmail.focus();
          return false;
        }
        if (!winners || parseInt(winners.value) < 1) {
          alert('Ingresa el numero de ganadores.');
          if (winners) winners.focus();
          return false;
        }
        if (!announce || !announce.value) {
          alert('Selecciona la fecha de anuncio de ganadores.');
          if (announce) announce.focus();
          return false;
        }

        // Validar premio
        var prizeEl = document.querySelector('input[name="prizeType"]:checked');
        var prizeType = prizeEl ? prizeEl.value : 'credits';

        if (prizeType === 'credits') {
          var creditsAmt = document.getElementById('fCreditsAmount');
          if (!creditsAmt || parseFloat(creditsAmt.value) < 1000) {
            alert('El monto de creditos debe ser >= 1,000.');
            if (creditsAmt) {
              toggleInputState(creditsAmt, false);
              creditsAmt.focus();
            }
            return false;
          }
        } else {
          var physPrize = document.getElementById('fPhysicalPrize');
          if (!physPrize || physPrize.value.trim() === '') {
            alert('Describe el premio fisico.');
            if (physPrize) physPrize.focus();
            return false;
          }
        }
        return true;
      }
      return false;

    case 4:
      // Step 4 (condiciones especiales) es opcional
      return true;

    default:
      return true;
  }
}

