  <script>
    // ============================================
    // GLOBAL STATE
    // ============================================
    let currentCountry = null;
    let currentCurrency = null;
    let currentCurrencySymbol = null;
    let previewVisible = false;
    let draftSaveTimeout = null;

    const currencyConfig = {
      'CO': { code: 'COP', symbol: '$', decimals: 0, name: 'Peso Colombiano' },
      'MX': { code: 'MXN', symbol: '$', decimals: 2, name: 'Peso Mexicano' },
      'CR': { code: 'CRC', symbol: '₡', decimals: 0, name: 'Colón Costarricense' },
      'BR': { code: 'BRL', symbol: 'R$', decimals: 2, name: 'Real Brasileño' },
