function loadAdminCountries() {
  const grid = document.getElementById('countriesGrid');
  google.script.run
    .withSuccessHandler(r => {
      const data = JSON.parse(r);
      const countries = ['CO','MX','CR','BR','AR','UY','CL','EC'];
      const map = {};
      if (data.templates) {
        data.templates.forEach(t => {
          if (!map[t.country_code]) map[t.country_code] = { types:[], hasActive:false };
          map[t.country_code].types.push({ type:t.campaign_type, status:t.status, version:t.version });
          if (t.status === 'active') map[t.country_code].hasActive = true;
        });
      }
      grid.innerHTML = countries.map(code => {
        const info = map[code]; const isActive = info && info.hasActive;
        let typesHtml = info ? info.types.map(t => {
          const icon = t.type === 'Cashback' ? '💰' : '🏆';
          const s = STATUS_MAP[t.status] || STATUS_MAP['draft'];
          return `<div class="flex items-center gap-1.5 text-[11px] text-gray-600"><span class="sts ${s.cls}" style="padding:2px 6px;font-size:9px;">${s.label}</span> ${icon} ${t.type}</div>`;
        }).join('') : '<p class="text-[11px] text-gray-400">Sin templates</p>';

        return `
          <div class="adm-card p-5 text-center ${isActive ? 'border-green-300 bg-green-50/30' : ''}">
            <span class="text-4xl block mb-2">${FLAG_MAP[code]}</span>
            <h3 class="font-extrabold text-gray-900">${COUNTRY_NAMES[code]}</h3>
            <span class="sts ${isActive ? 'sts-active' : 'sts-inactive'} mt-2 mb-3 inline-block">${isActive ? 'Operativo' : 'Pendiente'}</span>
            <div class="space-y-1 mt-2">${typesHtml}</div>
          </div>
        `;
      }).join('');
    })
    .withFailureHandler(() => { grid.innerHTML = '<p class="text-gray-500 col-span-4 text-center py-8">Error cargando</p>'; })
    .adminGetTemplates();
}

