/* PHASE 3: COMING SOON TOAST                   */
/* ============================================ */
.coming-soon-toast {
  position: fixed;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 24px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-1);
