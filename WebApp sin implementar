    };

    const frequentShops = [
      { name: 'Hamburguesas El Corral', legalName: 'HAMBURGUESAS EL CORRAL S.A.S.' },
      { name: 'McDonalds', legalName: 'ARCOS DORADOS COLOMBIA S.A.' },
      { name: 'Coca-Cola', legalName: 'INDUSTRIA NACIONAL DE GASEOSAS S.A.S.' },
      { name: 'Postobón', legalName: 'GASEOSAS POSADA TOBÓN S.A.' },
      { name: 'Frisby', legalName: 'FRISBY S.A.' },
      { name: 'Crepes & Waffles', legalName: 'CREPES & WAFFLES S.A.' },
      { name: 'Dominos Pizza', legalName: 'DOMINOS PIZZA COLOMBIA S.A.S.' },
      { name: 'Papa Johns', legalName: 'SIGLA S.A.S.' },
      { name: 'Juan Valdez', legalName: 'PROCAFECOL S.A.' },
      { name: 'Starbucks', legalName: 'STARBUCKS COFFEE COLOMBIA S.A.S.' },
      { name: 'KFC', legalName: 'INTERNATIONAL RESTAURANT GROUP SAS' },
      { name: 'Subway', legalName: 'QSR COLOMBIA S.A.S.' },
      { name: 'Wok', legalName: 'WOK S.A.S.' },
      { name: 'Presto', legalName: 'PRESTO S.A.' },
      { name: 'Jeno\'s Pizza', legalName: 'JENO\'S PIZZA S.A.' }
    ];

    let validationState = {
      section1: false,
      section2: false,
      section3: false,
      section4: true
    };

    // ============================================
    // TRIGGER FORM SUBMIT (desde botón externo)
    // ============================================
    function triggerFormSubmit() {
      const form = document.getElementById('legalForm');
      if (form) {
        // Crear y disparar evento submit
        const submitEvent = new Event('submit', { cancelable: true, bubbles: true });
        form.dispatchEvent(submitEvent);
      }
    }

    // ============================================
    // HISTORY MANAGEMENT
    // ============================================
    function getHistory() {
      const history = localStorage.getItem('motorLegal_history');
      return history ? JSON.parse(history) : [];
    }

    function addToHistory(docName, docUrl, type, shop) {
      const history = getHistory();
      history.unshift({
        id: Date.now(),
        docName,
        docUrl,
        type,
        shop,
        date: new Date().toISOString()
      });
      if (history.length > 20) history.pop();
      localStorage.setItem('motorLegal_history', JSON.stringify(history));
    }

    function renderHistory() {
      const history = getHistory();
      const listEl = document.getElementById('historyList');
      const emptyEl = document.getElementById('historyEmpty');

      if (history.length === 0) {
        listEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        return;
      }

      listEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');

      listEl.innerHTML = history.map(item => {
        const date = new Date(item.date);
        const dateStr = date.toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' });
        const timeStr = date.toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit' });
        const typeIcon = item.type === 'Cashback' ? '💰' : '🏆';
        
        return `
          <a href="${item.docUrl}" target="_blank" class="history-item block">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-2xl">${typeIcon}</span>
                <div>
                  <div class="font-bold text-gray-900 text-sm">${item.shop || 'Sin tienda'}</div>
                  <div class="text-xs text-gray-500">${item.type}</div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-xs text-gray-500">${dateStr}</div>
                <div class="text-xs text-gray-400">${timeStr}</div>
              </div>
            </div>
          </a>
        `;
      }).join('');
    }

    function showHistoryModal() {
      renderHistory();
      document.getElementById('historyModal').classList.remove('hidden');
    }

    function hideHistoryModal() {
      document.getElementById('historyModal').classList.add('hidden');
    }

    function clearHistory() {
      if (confirm('¿Seguro que quieres eliminar el historial?')) {
        localStorage.removeItem('motorLegal_history');
        renderHistory();
      }
    }

    // ============================================
    // DRAFT MANAGEMENT
    // ============================================
    function saveDraft() {
      clearTimeout(draftSaveTimeout);
      draftSaveTimeout = setTimeout(() => {
        const form = document.getElementById('legalForm');
        const formData = new FormData(form);
        const draft = {};
        
        formData.forEach((value, key) => {
          draft[key] = value;
        });
        
        draft.country = currentCountry;
        draft.timestamp = Date.now();
        
        localStorage.setItem('motorLegal_draft', JSON.stringify(draft));
        showDraftIndicator();
      }, 500);
    }

    function loadDraft() {
      const draft = localStorage.getItem('motorLegal_draft');
      if (!draft) return false;
      
      const data = JSON.parse(draft);
      
      if (Date.now() - data.timestamp > 24 * 60 * 60 * 1000) {
        clearDraft();
        return false;
      }
      
      return data;
    }

    function clearDraft() {
      localStorage.removeItem('motorLegal_draft');
      document.getElementById('draftIndicator').classList.add('hidden');
    }

    function showDraftIndicator() {
      const indicator = document.getElementById('draftIndicator');
      indicator.classList.remove('hidden');
      setTimeout(() => {
        indicator.classList.add('hidden');
      }, 2000);
    }

    function restoreDraft() {
      const draft = loadDraft();
      if (!draft) return;

      if (draft.country) {
        const countryData = {
          'CO': ['Colombia', 'COP', '$', '🇨🇴'],
          'MX': ['México', 'MXN', '$', '🇲🇽'],
          'CR': ['Costa Rica', 'CRC', '₡', '🇨🇷'],
          'BR': ['Brasil', 'BRL', 'R$', '🇧🇷'],
          'AR': ['Argentina', 'ARS', '$', '🇦🇷'],
          'UY': ['Uruguay', 'UYU', '$', '🇺🇾'],
          'CL': ['Chile', 'CLP', '$', '🇨🇱'],
          'EC': ['Ecuador', 'USD', '$', '🇪🇨']
        };
        
        if (countryData[draft.country]) {
          const [name, currency, symbol, flag] = countryData[draft.country];
          selectCountry(draft.country, name, currency, symbol, flag, true);
        }
      }

      setTimeout(() => {
        Object.keys(draft).forEach(key => {
          const el = document.getElementById(key) || document.querySelector(`[name="${key}"]`);
          if (el && key !== 'country' && key !== 'timestamp') {
            if (el.type === 'radio') {
              const radio = document.querySelector(`[name="${key}"][value="${draft[key]}"]`);
              if (radio) radio.checked = true;
            } else {
              el.value = draft[key];
            }
          }
        });

        toggleFormFields();
        togglePrizeFields();
        updateProgress();
        updatePreview();
      }, 100);
    }

    // ============================================
    // PREVIEW
    // ============================================
    function togglePreview() {
      const column = document.getElementById('previewColumn');
      previewVisible = !previewVisible;
      
      if (previewVisible) {
        column.classList.remove('hidden');
        column.classList.add('lg:block');
      } else {
        column.classList.add('hidden');
        column.classList.remove('lg:block');
      }
      
      updatePreview();
    }

    function updatePreview() {
      const previewEl = document.getElementById('previewContent');
      const type = document.getElementById('dynamicType').value;
      
      if (!type) {
        previewEl.innerHTML = `
          <p class="text-gray-400 text-center py-8">
            <i class="fa-solid fa-file-lines text-4xl mb-2 block"></i>
            Selecciona un tipo de campaña para ver la vista previa
          </p>
        `;
        return;
      }

      const getValue = (id) => {
        const el = document.getElementById(id);
        return el ? el.value : '';
      };

      const placeholder = (text) => `<span class="preview-placeholder">${text}</span>`;

      const campaignName = getValue('campaignName') || getValue('shopName') || placeholder('NOMBRE CAMPAÑA');
      const territory = getValue('territory') || placeholder('TERRITORIO');
      const startDate = getValue('startDate') ? formatDatePreview(getValue('startDate')) : placeholder('FECHA INICIO');
      const endDate = getValue('endDate') ? formatDatePreview(getValue('endDate')) : placeholder('FECHA FIN');
      const startTime = getValue('startTime') || '00:00';
      const endTime = getValue('endTime') || '23:59';
      const shop = getValue('shopName') || placeholder('TIENDA');

      if (type === 'Cashback') {
        const pct = getValue('cashbackPct') || placeholder('%');
        const cap = getValue('cap') ? Number(getValue('cap')).toLocaleString('es-CO') : placeholder('TOPE');
        const budget = getValue('budget') ? Number(getValue('budget')).toLocaleString('es-CO') : placeholder('PRESUPUESTO');

        previewEl.innerHTML = `
          <h1>TÉRMINOS Y CONDICIONES – CAMPAÑA "${String(campaignName).toUpperCase()}"</h1>
          <p>Por medio del presente documento se dan a conocer los términos y condiciones de la campaña denominada "<strong>${campaignName}</strong>"...</p>
          
          <h2>I. Territorio:</h2>
          <p>La Campaña será válida únicamente para las órdenes realizadas en <strong>${territory}</strong>.</p>
          
          <h2>II. Vigencia:</h2>
          <p>Campaña válida desde las <strong>${startTime}</strong> del <strong>${startDate}</strong> hasta las <strong>${endTime}</strong> del <strong>${endDate}</strong> y/o hasta agotar existencias (${budget} créditos).</p>
          
          <h2>IV. Tienda Participante:</h2>
          <p>Participará la tienda virtual <strong>"${shop}"</strong> al interior de la Plataforma Rappi.</p>
          
          <h2>VI. Beneficio:</h2>
          <p>Los usuarios recibirán el <strong>${pct}%</strong> del valor de su compra en Créditos, con un tope máximo de <strong>${cap}</strong> Créditos por usuario.</p>
          
          <p style="color: #6B7280; font-style: italic; margin-top: 20px;">[Vista previa simplificada - El documento final incluirá todas las cláusulas legales]</p>
        `;
      } else {
        const organizer = getValue('organizerLegalName') || placeholder('ORGANIZADOR');
        const winners = getValue('numberOfWinners') || placeholder('#');
        const criteria = getValue('winnerCriteria') || 'Mayor Venta ($)';
        const announcement = getValue('announcementDate') ? formatDatePreview(getValue('announcementDate')) : placeholder('FECHA ANUNCIO');

        const prizeType = document.querySelector('input[name="prizeType"]:checked')?.value || 'credits';
        let prizeText = '';
        if (prizeType === 'credits') {
          const amount = getValue('creditsAmount') ? Number(getValue('creditsAmount')).toLocaleString('es-CO') : placeholder('MONTO');
          prizeText = `<strong>${amount}</strong> Créditos de la App`;
        } else {
          prizeText = getValue('physicalPrizeDescription') || placeholder('DESCRIPCIÓN DEL PREMIO');
        }

        previewEl.innerHTML = `
          <h1>TÉRMINOS Y CONDICIONES – ACTIVIDAD PROMOCIONAL "${String(campaignName).toUpperCase()}"</h1>
          <p>Por medio del presente documento se dan a conocer las reglas de la actividad promocional denominada "<strong>${campaignName}</strong>"...</p>
          
          <h2>I. Organizador y Territorio:</h2>
          <p>La presente Actividad es organizada por <strong>${organizer}</strong>. Válida en <strong>${territory}</strong>.</p>
          
          <h2>II. Vigencia:</h2>
          <p>Desde las <strong>${startTime}</strong> del <strong>${startDate}</strong> hasta las <strong>${endTime}</strong> del <strong>${endDate}</strong>.</p>
          
          <h2>IV. Mecánica:</h2>
          <p>Ganarán los <strong>${winners}</strong> usuarios con el <strong>${criteria === 'Mayor Venta ($)' ? 'mayor valor acumulado en compras' : 'mayor cantidad de órdenes'}</strong> en la tienda <strong>"${shop}"</strong>.</p>
          
          <h2>V. Premio:</h2>
          <p>${prizeText}</p>
          
          <h2>VIII. Anuncio:</h2>
          <p>Los ganadores serán anunciados el <strong>${announcement}</strong>.</p>
          
          <p style="color: #6B7280; font-style: italic; margin-top: 20px;">[Vista previa simplificada - El documento final incluirá todas las cláusulas legales]</p>
        `;
      }
    }

    function formatDatePreview(dateStr) {
      if (!dateStr) return '';
      const date = new Date(dateStr + 'T12:00:00');
      const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
      return `${date.getDate()} de ${months[date.getMonth()]} de ${date.getFullYear()}`;
    }

    // ============================================
    // AUTOCOMPLETE
    // ============================================
    function showShopAutocomplete(input) {
      const value = input.value.toLowerCase();
      const dropdown = document.getElementById('shopAutocomplete');
      
      if (value.length < 2) {
        dropdown.classList.add('hidden');
        return;
      }

      const matches = frequentShops.filter(shop => 
        shop.name.toLowerCase().includes(value)
      );

      if (matches.length === 0) {
        dropdown.classList.add('hidden');
        return;
      }

      dropdown.innerHTML = matches.map(shop => `
        <div class="autocomplete-item" onmousedown="selectShop('${shop.name}', '${shop.legalName}')">
          <strong>${shop.name}</strong>
          <div class="text-xs text-gray-500">${shop.legalName}</div>
        </div>
      `).join('');

      dropdown.classList.remove('hidden');
    }

    function selectShop(name, legalName) {
      document.getElementById('shopName').value = name;
      
      const organizerInput = document.getElementById('organizerLegalName');
      if (organizerInput && !organizerInput.value) {
        organizerInput.value = legalName;
      }
      
      hideAutocomplete();
      saveDraft();
      updatePreview();
    }

    function showOrganizerAutocomplete(input) {
      const value = input.value.toLowerCase();
      const dropdown = document.getElementById('organizerAutocomplete');
      
      if (value.length < 2) {
        dropdown.classList.add('hidden');
        return;
      }

      const matches = frequentShops.filter(shop => 
        shop.legalName.toLowerCase().includes(value) || 
        shop.name.toLowerCase().includes(value)
      );

      if (matches.length === 0) {
        dropdown.classList.add('hidden');
        return;
      }

      dropdown.innerHTML = matches.map(shop => `
        <div class="autocomplete-item" onmousedown="selectOrganizer('${shop.legalName}')">
          <strong>${shop.legalName}</strong>
          <div class="text-xs text-gray-500">${shop.name}</div>
        </div>
      `).join('');

      dropdown.classList.remove('hidden');
    }

    function selectOrganizer(legalName) {
      document.getElementById('organizerLegalName').value = legalName;
      hideAutocomplete();
      saveDraft();
      updatePreview();
    }

    function hideAutocomplete() {
      setTimeout(() => {
        document.querySelectorAll('.autocomplete-dropdown').forEach(el => {
          el.classList.add('hidden');
        });
      }, 200);
    }

    // ============================================
    // NAVIGATION
    // ============================================
    function showCountrySelector() {
      document.getElementById('countrySelector').classList.remove('hidden');
    }

    function hideCountrySelector() {
      document.getElementById('countrySelector').classList.add('hidden');
    }

    function selectCountry(code, name, currency, symbol, flag, skipDraftCheck = false) {
      currentCountry = code;
      currentCurrency = currency;
      currentCurrencySymbol = symbol;

      document.getElementById('selectedCountryCode').value = code;
      document.getElementById('selectedCurrencyCode').value = currency;
      document.getElementById('selectedCurrencySymbol').value = symbol;

      document.getElementById('selectedCountryFlag').textContent = flag;
      document.getElementById('selectedCountryName').textContent = name;
      document.getElementById('selectedCurrency').textContent = currency;

      updateCurrencyPlaceholders();

      document.getElementById('landingPage').classList.add('hidden');
      document.getElementById('countrySelector').classList.add('hidden');
      document.getElementById('mainForm').classList.remove('hidden');
      
      window.scrollTo(0, 0);

      if (!skipDraftCheck) {
        const draft = loadDraft();
        if (draft && draft.country === code) {
          if (confirm('Tienes un borrador guardado. ¿Deseas recuperarlo?')) {
            restoreDraft();
          } else {
            clearDraft();
          }
        }
      }
    }

    function updateCurrencyPlaceholders() {
      const config = currencyConfig[currentCountry];
      if (!config) return;

      const capTooltip = document.getElementById('capTooltip');
      const budgetTooltip = document.getElementById('budgetTooltip');
      
      if (capTooltip) capTooltip.textContent = `Máximo por usuario (${config.code})`;
      if (budgetTooltip) budgetTooltip.textContent = `Presupuesto total (${config.code})`;
    }

    function backToLanding() {
  if (confirm('¿Seguro que quieres volver al inicio? Tu borrador se guardará automáticamente.')) {
    saveDraft();
    document.getElementById('mainForm').classList.add('hidden');
    try { document.getElementById('adminPanel').classList.add('hidden'); } catch(e) {}
    document.getElementById('landingPage').classList.remove('hidden');
    window.scrollTo(0, 0);
  }
}

    // ============================================
    // DATA TRANSFER MODAL
    // ============================================
    function showDataTransferModal() {
      document.getElementById('dataTransferModal').classList.remove('hidden');
    }

    function hideDataTransferModal() {
      document.getElementById('dataTransferModal').classList.add('hidden');
    }

    function confirmDataTransferAgreement() {
      document.getElementById('dataTransferConfirmed').value = 'true';
      hideDataTransferModal();
      submitForm();
    }

    // ============================================
    // VALIDATIONS
    // ============================================
    function validateEmail(input) {
      const value = input.value.trim();
      const isValid = value.endsWith('@rappi.com') && value.includes('@');
      toggleInputState(input, isValid);
      updateProgress();
      return isValid;
    }

    function validateShopName(input) {
      const isValid = input.value.trim().length >= 3;
      toggleInputState(input, isValid);
      updateProgress();
      return isValid;
    }

    function validateTerritory(input) {
      const isValid = input.value.trim().length >= 3;
      toggleInputState(input, isValid);
      updateProgress();
      return isValid;
    }

    function validateDates() {
      const startDate = document.getElementById('startDate').value;
      const endDate = document.getElementById('endDate').value;
      const endInput = document.getElementById('endDate');
      
      if (startDate && endDate) {
        const isValid = new Date(endDate) >= new Date(startDate);
        toggleInputState(endInput, isValid);
        updateProgress();
        return isValid;
      }
      return true;
    }

    function validatePercentage(input) {
      const value = parseFloat(input.value);
      const isValid = !isNaN(value) && value >= 1 && value <= 100;
      toggleInputState(input, isValid);
      updateProgress();
      return isValid;
    }

    function validateCap(input) {
      const value = parseFloat(input.value);
      const isValid = !isNaN(value) && value >= 1000;
      toggleInputState(input, isValid);
      updateProgress();
      return isValid;
    }

    function validateBudget(input) {
      const value = parseFloat(input.value);
      const isValid = !isNaN(value) && value >= 10000;
      toggleInputState(input, isValid);
      updateProgress();
      return isValid;
    }

    function validateExtraEmails(input) {
      const value = input.value.trim();
      if (value === '') return true;
      
      const emails = value.split(',').map(e => e.trim());
      const isValid = emails.every(email => email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/));
      
      toggleInputState(input, isValid);
      return isValid;
    }

    function toggleInputState(input, isValid) {
      const errorMsg = input.parentElement.querySelector('.error-message');
      
      if (isValid) {
        input.classList.remove('error');
        input.classList.add('success');
        if (errorMsg) errorMsg.classList.remove('show');
      } else {
        input.classList.remove('success');
        input.classList.add('error');
        if (errorMsg) errorMsg.classList.add('show');
        
        input.classList.add('shake');
        setTimeout(() => input.classList.remove('shake'), 300);
      }
    }

    function updateProgress() {
      const email = document.getElementById('userEmail');
      const dynamicType = document.getElementById('dynamicType');
      validationState.section1 = email.value.includes('@rappi.com') && dynamicType.value !== '';

      const shopName = document.getElementById('shopName');
      const territory = document.getElementById('territory');
      const startDate = document.getElementById('startDate');
      const endDate = document.getElementById('endDate');
      validationState.section2 = shopName.value.trim() !== '' && 
                                 territory.value.trim() !== '' &&
                                 startDate.value !== '' && 
                                 endDate.value !== '' &&
                                 new Date(endDate.value) >= new Date(startDate.value);

      if (dynamicType.value === 'Cashback') {
        const pct = document.getElementById('cashbackPct');
        const cap = document.getElementById('cap');
        const budget = document.getElementById('budget');
        validationState.section3 = pct.value !== '' && cap.value !== '' && budget.value !== '' &&
                                   parseFloat(pct.value) >= 1 && parseFloat(pct.value) <= 100 &&
                                   parseFloat(cap.value) >= 1000 &&
                                   parseFloat(budget.value) >= 10000;
      } else if (dynamicType.value === 'Concurso Mayor Comprador') {
        const organizer = document.getElementById('organizerLegalName');
        const phone = document.getElementById('organizerPhone');
        const orgEmail = document.getElementById('organizerEmail');
        const winners = document.getElementById('numberOfWinners');
        const announcement = document.getElementById('announcementDate');
        
        const prizeType = document.querySelector('input[name="prizeType"]:checked')?.value;
        let prizeValid = false;
        
        if (prizeType === 'credits') {
          const amount = document.getElementById('creditsAmount');
          prizeValid = amount.value !== '' && parseFloat(amount.value) >= 1000;
        } else {
          const desc = document.getElementById('physicalPrizeDescription');
          prizeValid = desc.value.trim() !== '';
        }
        
        validationState.section3 = organizer.value.trim() !== '' &&
                                   phone.value.trim() !== '' &&
                                   orgEmail.value.includes('@') &&
                                   winners.value !== '' &&
                                   announcement.value !== '' &&
                                   prizeValid;
      } else {
        // Cuando no hay tipo seleccionado
        validationState.section3 = false;
      }

      const completedSections = Object.values(validationState).filter(v => v).length;
      const progress = (completedSections / 4) * 100;
      document.getElementById('progressFill').style.width = progress + '%';

      updateSteps();

      const allValid = validationState.section1 && validationState.section2 && validationState.section3;
      const submitBtn = document.getElementById('btnSubmit');
      const submitHint = document.getElementById('submitHint');
      
      submitBtn.disabled = !allValid;
      if (allValid) {
        submitHint.textContent = '¡Listo! Haz clic para generar el documento';
        submitHint.classList.add('text-green-600');
        submitHint.classList.remove('text-gray-500');
      } else {
        submitHint.textContent = 'Completa los campos requeridos';
        submitHint.classList.add('text-gray-500');
        submitHint.classList.remove('text-green-600');
      }
    }

    function updateSteps() {
      for (let i = 1; i <= 4; i++) {
        const step = document.getElementById(`step${i}`);
        const isValid = validationState[`section${i}`];
        
        step.classList.remove('active', 'completed');
        if (isValid) {
          step.classList.add('completed');
        }
      }
      
      for (let i = 1; i <= 4; i++) {
        if (!validationState[`section${i}`]) {
          document.getElementById(`step${i}`).classList.add('active');
          break;
        }
      }
    }

