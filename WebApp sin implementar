          <span class="text-lg">${actionIcons[l.action]||'📋'}</span>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-bold text-gray-800">${l.details}</p>
            <p class="text-[10px] text-gray-400">${l.actor} · ${l.timestamp}</p>
          </div>
        </div>
      `).join('')}</div>`;
    })
    .withFailureHandler(() => { loading.classList.add('hidden'); })
    .adminGetApprovalLog();
}
// ============================================================
// TEMPLATE WIZARD — Lógica JavaScript
// ============================================================
const TW = { step: 1, source: 'text', originalText: '', docId: null, docTitle: null, detections: [], mappings: [], metadata: {}, currentFilter: 'all' };

function twSelectSource(source) {
  TW.source = source;
  document.getElementById('tw-tab-text').classList.toggle('active', source === 'text');
  document.getElementById('tw-tab-doc').classList.toggle('active', source === 'doc');
  document.getElementById('tw-input-text').classList.toggle('hidden', source !== 'text');
  document.getElementById('tw-input-doc').classList.toggle('hidden', source !== 'doc');
}

document.getElementById('tw-text-input')?.addEventListener('input', function() {
  document.getElementById('tw-text-count').textContent = this.value.length.toLocaleString() + ' caracteres';
});

async function twLoadFromDoc() {
  const url = document.getElementById('tw-doc-url').value.trim();
  if (!url) return alert('Ingresa la URL del Google Doc');
  twSetDocLoading(true);
  try {
    // FIX: Agregamos userEmail
    const res = await twCallBackend('tw_fetchDocContent', { docUrl: url, userEmail: currentUser.email });
    if (!res.success) throw new Error(res.message);
    TW.originalText = res.data.text; TW.docId = res.data.docId; TW.docTitle = res.data.docTitle;
    document.getElementById('tw-doc-title').textContent = res.data.docTitle;
    document.getElementById('tw-doc-meta').textContent = `${res.data.wordCount.toLocaleString()} palabras · ${res.data.charCount.toLocaleString()} caracteres`;
    document.getElementById('tw-doc-preview').classList.remove('hidden');
    alert('Documento cargado correctamente');
  } catch (e) { alert(e.message); } finally { twSetDocLoading(false); }
}

function twSetDocLoading(loading) {
  const btn = document.querySelector('#tw-input-doc button');
  if(btn) { btn.disabled = loading; btn.innerHTML = loading ? 'Cargando...' : '<i class="fa-solid fa-cloud-arrow-down"></i> Cargar'; }
}

async function twRunAnalysis() {
  if (TW.source === 'text') TW.originalText = document.getElementById('tw-text-input').value.trim();
  if (!TW.originalText || TW.originalText.length < 50) return alert('El texto es muy corto.');
  const country = document.getElementById('tw-country').value;
  const type = document.getElementById('tw-campaign-type').value;
  if (!country || !type) return alert('Selecciona el país y tipo de campaña antes de analizar.');
  
  TW.metadata = { countryCode: country, campaignType: type, version: document.getElementById('tw-version').value || '1.0', notes: document.getElementById('tw-notes').value };
  twGoToStep(2);
  
  try {
    // FIX: Agregamos userEmail
    const res = await twCallBackend('tw_analyzeText', { text: TW.originalText, countryCode: country, campaignType: type, userEmail: currentUser.email });
    if (!res.success) throw new Error(res.message);
    TW.detections = res.data;
    TW.mappings = (res.data.detections || []).map((d, i) => ({ id: 'map_' + i, original_text: d.original_text, placeholder: d.suggested_placeholder, label: d.label || d.suggested_placeholder, confidence: d.confidence || 'MEDIUM', context: d.context || '', occurrences: d.occurrences || 1, confirmed: d.confidence === 'HIGH' }));
    twGoToStep(3); twRenderMappings(); twUpdatePreview();
  } catch (e) { alert('Error al analizar: ' + e.message); twGoToStep(1); }
}

function twRenderMappings() {
  const tbody = document.getElementById('tw-mappings-tbody');
  const filtered = TW.mappings.filter(m => TW.currentFilter === 'all' || m.confidence === TW.currentFilter);
  tbody.innerHTML = filtered.map(m => `
    <tr id="row-${m.id}" class="${m.confirmed ? 'bg-green-50' : ''}">
      <td><button class="tw-confirm-toggle ${m.confirmed ? 'confirmed' : ''}" id="toggle-${m.id}" onclick="twToggleConfirm('${m.id}')"></button></td>
      <td><span class="font-mono text-xs bg-gray-100 px-2 py-1 rounded">${escapeHtml(m.original_text)}</span>${m.context ? `<p class="text-xs text-gray-400 mt-1 truncate max-w-xs">...${escapeHtml(m.context)}...</p>` : ''}</td>
      <td><div class="tw-placeholder-chip" id="chip-${m.id}" onclick="twEditPlaceholder('${m.id}')">{{<span id="ph-text-${m.id}">${m.placeholder}</span>}}<i class="fa-solid fa-pen-to-square text-xs opacity-50 ml-1"></i></div><p class="text-[10px] text-gray-400 mt-1">${m.label}</p></td>
      <td><span class="badge badge-${m.confidence} text-xs px-2 py-0.5 rounded-full font-bold">${m.confidence}</span></td>
      <td><button onclick="twRemoveMapping('${m.id}')" class="text-gray-300 hover:text-red-400"><i class="fa-solid fa-xmark"></i></button></td>
    </tr>`).join('');
  twUpdateSummary();
}

function twToggleConfirm(id) {
  const m = TW.mappings.find(x => x.id === id); if (!m) return;
  m.confirmed = !m.confirmed;
  document.getElementById('toggle-' + id).classList.toggle('confirmed', m.confirmed);
  document.getElementById('row-' + id).classList.toggle('bg-green-50', m.confirmed);
  twUpdateSummary(); twUpdatePreview();
}

function twEditPlaceholder(id) {
  const m = TW.mappings.find(x => x.id === id); if (!m) return;
  const chip = document.getElementById('chip-' + id); const span = document.getElementById('ph-text-' + id);
  chip.classList.add('editing');
  const input = document.createElement('input'); input.type = 'text'; input.value = m.placeholder; input.className = 'tw-placeholder-input';
  span.replaceWith(input); input.focus(); input.select();
  const save = () => { m.placeholder = input.value.toUpperCase().replace(/[^A-Z0-9_]/g, '_'); chip.classList.remove('editing'); const newSpan = document.createElement('span'); newSpan.id = 'ph-text-' + id; newSpan.textContent = m.placeholder; input.replaceWith(newSpan); twUpdatePreview(); };
  input.addEventListener('blur', save); input.addEventListener('keydown', e => { if (e.key === 'Enter') save(); });
}

function twRemoveMapping(id) { TW.mappings = TW.mappings.filter(m => m.id !== id); document.getElementById('row-' + id)?.remove(); twUpdateSummary(); twUpdatePreview(); }
function twFilterMappings(level) { TW.currentFilter = level; twRenderMappings(); }
function twConfirmAll() { TW.mappings.forEach(m => { if (m.confidence === 'HIGH') m.confirmed = true; }); twRenderMappings(); twUpdatePreview(); }

function twAddManualMapping() {
  const text = document.getElementById('tw-manual-text').value.trim(); const ph = document.getElementById('tw-manual-placeholder').value.trim().toUpperCase();
  if (!text || !ph) return alert('Completa los dos campos');
  TW.mappings.push({ id: 'map_manual_' + Date.now(), original_text: text, placeholder: ph, label: ph, confidence: 'HIGH', occurrences: 1, confirmed: true });
  document.getElementById('tw-manual-text').value = ''; document.getElementById('tw-manual-placeholder').value = '';
  twRenderMappings(); twUpdatePreview();
}

function twUpdateSummary() {
  const confirmed = TW.mappings.filter(m => m.confirmed).length;
  document.getElementById('tw-confirmed-count').textContent = `${confirmed} confirmados`;
  document.getElementById('tw-btn-continue').disabled = confirmed === 0;
}

function twUpdatePreview() {
  const previewEl = document.getElementById('tw-preview-content'); if (!previewEl) return;
  let text = TW.originalText;
  TW.mappings.filter(m => m.confirmed).forEach(m => {
    text = text.replace(new RegExp(m.original_text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), `⟪{{${m.placeholder}}}⟫`);
  });
  previewEl.innerHTML = text.split('\n').map(line => `<p class="mb-1">${escapeHtml(line).replace(/⟪\{\{(\w+)\}\}⟫/g, '<span class="tw-placeholder-highlight">{{$1}}</span>')}</p>`).join('');
}

function twGoToStep(n) {
  [1,2,3,4,'success'].forEach(s => document.getElementById('tw-step-' + s)?.classList.add('hidden'));
  document.getElementById('tw-step-' + n)?.classList.remove('hidden');
  TW.step = n;
  [1,2,3,4].forEach(i => {
    const stepEl = document.getElementById('twstep-' + i); const connEl = document.getElementById('twconn-' + i);
    if (!stepEl) return;
    stepEl.classList.remove('active', 'done');
    if (i < n) stepEl.classList.add('done'); else if (i === n) stepEl.classList.add('active');
    if (connEl) connEl.classList.toggle('done', i < n);
  });
  if (n === 4) twRenderFinalSummary();
}

function twRenderFinalSummary() {
  const confirmed = TW.mappings.filter(m => m.confirmed); const { countryCode, campaignType, version } = TW.metadata;
  document.getElementById('tw-final-summary').innerHTML = `
    <div class="bg-gray-50 rounded-xl p-4 text-center"><p class="text-3xl font-black text-rappi">${confirmed.length}</p><p class="text-xs text-gray-500 font-semibold mt-1">Placeholders</p></div>
    <div class="bg-gray-50 rounded-xl p-4 text-center"><p class="text-lg font-black text-gray-800">${countryCode}</p><p class="text-xs text-gray-500 font-semibold mt-1">País</p></div>
    <div class="bg-gray-50 rounded-xl p-4 text-center"><p class="text-sm font-black text-gray-800">${campaignType}</p><p class="text-xs text-gray-500 font-semibold mt-1">Tipo</p></div>
  `;
}

function twCheckResponsibility() { document.getElementById('tw-btn-create').disabled = !document.getElementById('tw-responsibility-check').checked; }

async function twCreateTemplate() {
  const btn = document.getElementById('tw-btn-create'); btn.disabled = true; btn.innerHTML = 'Creando template...';
  try {
    const confirmedMappings = TW.mappings.filter(m => m.confirmed).map(m => ({ original_text: m.original_text, placeholder: m.placeholder, label: m.label, confirmed: true }));
    
    // FIX MAESTRO: Agregamos userEmail al payload
    const res = await twCallBackend('tw_createTemplate', { 
      originalText: TW.originalText, 
      mappings: confirmedMappings, 
      metadata: TW.metadata,
      userEmail: currentUser.email 
    });
    
    if (!res.success) throw new Error(res.message);
    document.getElementById('tw-step-4').classList.add('hidden'); document.getElementById('tw-step-success').classList.remove('hidden');
    document.getElementById('tw-success-msg').textContent = res.message;
    document.getElementById('tw-success-details').innerHTML = `<p>Doc: <a href="${res.data.docUrl}" target="_blank" class="text-rappi font-bold hover:underline">Abrir</a></p><p>Estado: ${res.data.status}</p>`;
    [1,2,3,4].forEach(i => { document.getElementById('twstep-'+i)?.classList.add('done'); document.getElementById('twstep-'+i)?.classList.remove('active'); document.getElementById('twconn-'+i)?.classList.add('done'); });
  } catch (e) { alert('Error: ' + e.message); btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Crear Template'; }
}

function twReset() {
  TW.step = 1; TW.source = 'text'; TW.originalText = ''; TW.docId = null; TW.mappings = []; TW.metadata = {};
  document.getElementById('tw-text-input').value = ''; document.getElementById('tw-doc-url').value = ''; document.getElementById('tw-responsibility-check').checked = false;
  ['success',2,3,4].forEach(s => document.getElementById('tw-step-' + s)?.classList.add('hidden'));
  document.getElementById('tw-step-1').classList.remove('hidden'); twGoToStep(1);
}

function twCallBackend(action, data) {
  return new Promise((resolve, reject) => {
    // 1. Definimos qué hacer si hay éxito
    const onSuccess = res => {
      if (typeof res === 'string') { 
        try { resolve(JSON.parse(res)); } catch (e) { resolve({ success: true, data: res }); } 
      } else { 
        resolve(res || { success: true }); 
      }
    };
    
    // 2. Definimos qué hacer si falla
    const onFailure = err => reject(new Error(err.message || 'Error en el servidor de Google'));

    // 3. Preparamos el motor de Google
    const api = google.script.run.withSuccessHandler(onSuccess).withFailureHandler(onFailure);

    // 4. Llamadas EXPLÍCITAS con escudo contra Caché de Google Apps Script 🛡️
    if (action === 'tw_analyzeText') {
      if (typeof api.analyzeTextForPlaceholders !== 'function') {
        return reject(new Error("⚠️ Error de Sincronización: Estás en una versión desactualizada. Ve a 'Implementaciones > Probar implementaciones' y usa la URL que termina en /dev"));
      }
      api.analyzeTextForPlaceholders(data);
    } else if (action === 'tw_fetchDocContent') {
      if (typeof api.fetchGoogleDocContent !== 'function') return reject(new Error("Error: fetchGoogleDocContent no existe en esta versión."));
      api.fetchGoogleDocContent(data);
    } else if (action === 'tw_createTemplate') {
      if (typeof api.createTemplateFromWizard !== 'function') return reject(new Error("Error: createTemplateFromWizard no existe en esta versión."));
      api.createTemplateFromWizard(data);
    } else {
      reject(new Error("Acción no reconocida por el motor: " + action));
    }
  });
}

function escapeHtml(str) { return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

