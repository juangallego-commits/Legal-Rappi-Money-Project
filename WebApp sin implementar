\<\!DOCTYPE html\>  
\<html lang="es"\>  
\<head\>  
  \<base target="\_top"\>  
  \<meta charset="UTF-8"\>  
  \<meta name="viewport" content="width=device-width, initial-scale=1.0"\>  
  \<title\>RappiMind | Generador Inteligente de T\&C\</title\>  
  \<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700\&family=Outfit:wght@300;400;500;600;700;800;900\&display=swap" rel="stylesheet"\>  
  \<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"\>  
  \<style\>  
    /\* \============================================ \*/  
    /\* DESIGN TOKENS                               \*/  
    /\* \============================================ \*/  
    :root {  
      \--bg-0: \#08080C;  
      \--bg-1: \#0E0E14;  
      \--bg-2: \#14141C;  
      \--bg-3: \#1A1A25;  
      \--bg-4: \#22222F;  
      \--border: \#2A2A3C;  
      \--border-subtle: \#1E1E2C;  
      \--border-hover: \#3A3A50;  
      \--text-0: \#F5F5F7;  
      \--text-1: \#C8C8D4;  
      \--text-2: \#8888A0;  
      \--text-3: \#55556A;  
      \--accent: \#FF5C00;  
      \--accent-hover: \#FF7A33;  
      \--accent-muted: rgba(255, 92, 0, 0.12);  
      \--accent-glow: rgba(255, 92, 0, 0.08);  
      \--accent-glow-strong: rgba(255, 92, 0, 0.25);  
      \--success: \#00D68F;  
      \--success-muted: rgba(0, 214, 143, 0.12);  
      \--warning: \#FFB800;  
      \--warning-muted: rgba(255, 184, 0, 0.12);  
      \--error: \#FF4757;  
      \--error-muted: rgba(255, 71, 87, 0.12);  
      \--purple: \#8B5CF6;  
      \--purple-muted: rgba(139, 92, 246, 0.12);  
      \--radius-sm: 8px;  
      \--radius: 12px;  
      \--radius-lg: 16px;  
      \--radius-xl: 20px;  
      \--shadow-sm: 0 2px 8px rgba(0,0,0,0.3);  
      \--shadow-md: 0 8px 24px rgba(0,0,0,0.4);  
      \--shadow-lg: 0 16px 48px rgba(0,0,0,0.5);  
      \--transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);  
    }

    \* { margin: 0; padding: 0; box-sizing: border-box; }

    body {  
      font-family: 'Outfit', sans-serif;  
      background: var(--bg-0);  
      color: var(--text-0);  
      min-height: 100vh;  
      overflow-x: hidden;  
      \-webkit-font-smoothing: antialiased;  
    }

    .grid-bg {  
      position: fixed; inset: 0; z-index: 0; pointer-events: none;  
      background-image:  
        linear-gradient(rgba(255,92,0,0.02) 1px, transparent 1px),  
        linear-gradient(90deg, rgba(255,92,0,0.02) 1px, transparent 1px);  
      background-size: 64px 64px;  
    }  
    .glow-orb { position: fixed; pointer-events: none; z-index: 0; border-radius: 50%; filter: blur(120px); }  
    .glow-orb-1 { width: 600px; height: 600px; top: \-200px; left: \-100px; background: \#FF5C00; opacity: 0.12; }  
    .glow-orb-2 { width: 400px; height: 400px; bottom: \-150px; right: \-50px; background: \#FF8B69; opacity: 0.06; }

    .hidden { display: none \!important; }  
    .mono { font-family: 'JetBrains Mono', monospace; }

    ::-webkit-scrollbar { width: 6px; }  
    ::-webkit-scrollbar-track { background: transparent; }  
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    /\* \============================================ \*/  
    /\* ANIMATIONS                                  \*/  
    /\* \============================================ \*/  
    @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }  
    @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }  
    @keyframes float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-10px); } }  
    @keyframes pulse-glow { 0%,100% { box-shadow:0 0 20px rgba(255,92,0,0.3); } 50% { box-shadow:0 0 50px rgba(255,92,0,0.5); } }  
    @keyframes slideDown { from { opacity:0; transform:translateY(-10px) scale(0.98); } to { opacity:1; transform:translateY(0) scale(1); } }  
    @keyframes spin { to { transform:rotate(360deg); } }  
    @keyframes slideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }  
    @keyframes bounceIn { 0% { transform:scale(0); } 60% { transform:scale(1.1); } 100% { transform:scale(1); } }  
    @keyframes tooltipPulse { 0%,100% { box-shadow:0 0 0 0 rgba(255,92,0,0.3); } 50% { box-shadow:0 0 0 12px rgba(255,92,0,0); } }

    .anim-up { animation: fadeUp 0.5s cubic-bezier(0.16,1,0.3,1) forwards; opacity:0; }  
    .d1{animation-delay:.05s}.d2{animation-delay:.1s}.d3{animation-delay:.15s}  
    .d4{animation-delay:.2s}.d5{animation-delay:.25s}.d6{animation-delay:.3s}

    /\* \============================================ \*/  
    /\* SHARED COMPONENTS                           \*/  
    /\* \============================================ \*/  
    .badge { display:inline-flex; align-items:center; gap:5px; padding:4px 10px; border-radius:20px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; }  
    .badge-accent { background:var(--accent-muted); color:var(--accent); }  
    .badge-success { background:var(--success-muted); color:var(--success); }  
    .badge-warning { background:var(--warning-muted); color:var(--warning); }  
    .badge-purple { background:var(--purple-muted); color:var(--purple); }

    .btn-primary {  
      padding:12px 28px; background:linear-gradient(135deg,\#FF5C00,\#FF7A33);  
      border:none; border-radius:var(--radius); color:white;  
      font-family:'Outfit',sans-serif; font-size:14px; font-weight:700;  
      cursor:pointer; display:inline-flex; align-items:center; gap:10px;  
      transition:all var(--transition); box-shadow:0 8px 24px rgba(255,92,0,0.3);  
      position:relative; overflow:hidden;  
    }  
    .btn-primary::before { content:''; position:absolute; inset:0; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.1),transparent); transform:translateX(-100%); transition:transform 0.5s; }  
    .btn-primary:hover::before { transform:translateX(100%); }  
    .btn-primary:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 12px 32px rgba(255,92,0,0.4); }  
    .btn-primary:disabled { opacity:0.3; cursor:not-allowed; transform:none; }

    .btn-secondary { padding:10px 20px; background:var(--bg-3); border:1.5px solid var(--border); border-radius:var(--radius); color:var(--text-1); font-family:'Outfit',sans-serif; font-size:13px; font-weight:600; cursor:pointer; transition:all var(--transition); }  
    .btn-secondary:hover { border-color:var(--border-hover); background:var(--bg-4); }

    .kbd { padding:2px 7px; background:rgba(255,255,255,0.1); border-radius:5px; font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:600; }

    /\* \============================================ \*/  
    /\* NAV                                         \*/  
    /\* \============================================ \*/  
    .nav { position:sticky; top:0; z-index:50; background:rgba(8,8,12,0.8); backdrop-filter:blur(20px) saturate(1.5); border-bottom:1px solid var(--border-subtle); padding:0 24px; height:56px; display:flex; align-items:center; justify-content:space-between; }  
    .nav-brand { display:flex; align-items:center; gap:12px; }  
    .nav-logo { width:34px; height:34px; border-radius:10px; display:flex; align-items:center; justify-content:center; position:relative; }  
    .nav-logo svg { width:28px; height:28px; }  
    .nav-title { font-weight:800; font-size:15px; letter-spacing:-0.5px; }  
    .nav-title span { color:var(--text-3); font-weight:400; font-size:12px; margin-left:6px; }  
    .nav-right { display:flex; align-items:center; gap:10px; }  
    .nav-btn { display:flex; align-items:center; gap:6px; padding:7px 14px; border-radius:var(--radius-sm); background:transparent; border:none; color:var(--text-2); font-size:13px; font-weight:600; font-family:'Outfit',sans-serif; cursor:pointer; transition:all var(--transition); }  
    .nav-btn:hover { color:var(--text-0); background:var(--bg-3); }  
    .nav-chip { display:flex; align-items:center; gap:6px; padding:5px 12px; border-radius:20px; background:var(--bg-3); border:1px solid var(--border); font-size:11px; font-weight:700; color:var(--text-2); }  
    .nav-chip .dot { width:6px; height:6px; border-radius:50%; background:var(--success); box-shadow:0 0 8px rgba(0,214,143,0.6); }

    /\* Brain SVG Logo \*/  
    .brain-logo { filter: drop-shadow(0 0 12px rgba(255,92,0,0.4)); }

    /\* \============================================ \*/  
    /\* MODAL SYSTEM                                \*/  
    /\* \============================================ \*/  
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.7); backdrop-filter:blur(8px); z-index:60; display:flex; align-items:center; justify-content:center; padding:24px; animation:fadeIn 0.2s; }  
    .modal-box { background:var(--bg-2); border:1px solid var(--border); border-radius:var(--radius-xl); padding:32px; max-width:520px; width:100%; max-height:90vh; overflow-y:auto; animation:slideDown 0.3s cubic-bezier(0.16,1,0.3,1); box-shadow:var(--shadow-lg); }  
    .modal-close { width:32px; height:32px; border-radius:8px; background:var(--bg-3); border:1px solid var(--border); color:var(--text-2); font-size:14px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all var(--transition); }  
    .modal-close:hover { background:var(--bg-4); color:var(--text-0); }

    /\* \============================================ \*/  
    /\* LANDING PAGE                                \*/  
    /\* \============================================ \*/  
    .hero { min-height:70vh; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; padding:80px 24px; }  
    .hero-glow { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:800px; height:800px; background:radial-gradient(circle,rgba(255,92,0,0.1) 0%,transparent 70%); pointer-events:none; }  
    .hero-content { text-align:center; max-width:640px; position:relative; z-index:2; }  
    .hero-icon { width:88px; height:88px; display:flex; align-items:center; justify-content:center; margin:0 auto 32px; animation:float 4s ease-in-out infinite; }  
    .hero h1 { font-size:52px; font-weight:900; letter-spacing:-2px; line-height:1.05; margin-bottom:16px; }  
    .hero h1 .gradient-text { background:linear-gradient(135deg,\#FF5C00,\#FFB86C); \-webkit-background-clip:text; \-webkit-text-fill-color:transparent; background-clip:text; }  
    .hero p { font-size:17px; color:var(--text-2); line-height:1.7; margin-bottom:36px; }  
    .hero-cta { padding:16px 36px; font-size:16px; font-weight:800; border-radius:var(--radius-lg); animation:pulse-glow 3s ease-in-out infinite; }

    .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; max-width:700px; margin:-40px auto 0; padding:0 24px; position:relative; z-index:3; }  
    .stat-card { background:var(--bg-2); border:1px solid var(--border); border-radius:var(--radius); padding:20px; text-align:center; transition:all var(--transition); }  
    .stat-card:hover { border-color:var(--accent); transform:translateY(-4px); }  
    .stat-value { font-size:28px; font-weight:900; color:var(--accent); }  
    .stat-label { font-size:11px; color:var(--text-3); font-weight:600; margin-top:4px; text-transform:uppercase; letter-spacing:1px; }

    .features-section { max-width:900px; margin:80px auto; padding:0 24px; }  
    .features-title { text-align:center; font-size:32px; font-weight:800; letter-spacing:-1px; margin-bottom:48px; }  
    .features-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }  
    .feature-card { background:var(--bg-2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:28px; transition:all 0.3s; }  
    .feature-card:hover { border-color:var(--accent); transform:translateY(-6px); box-shadow:0 12px 32px rgba(0,0,0,0.3); }  
    .feature-icon { width:48px; height:48px; border-radius:var(--radius); display:flex; align-items:center; justify-content:center; font-size:22px; margin-bottom:16px; }  
    .fi-orange { background:var(--accent-muted); color:var(--accent); }  
    .fi-green { background:var(--success-muted); color:var(--success); }  
    .fi-blue { background:rgba(59,130,246,0.12); color:\#60A5FA; }  
    .feature-card h4 { font-size:16px; font-weight:700; margin-bottom:8px; }  
    .feature-card p { font-size:13px; color:var(--text-2); line-height:1.6; }

    .landing-footer { border-top:1px solid var(--border-subtle); padding:32px 24px; text-align:center; }  
    .landing-footer p { font-size:12px; color:var(--text-3); }

    /\* \============================================ \*/  
    /\* RESPONSIBILITY CHECKS                       \*/  
    /\* \============================================ \*/  
    .resp-check { display:flex; align-items:flex-start; gap:14px; padding:16px; border-radius:var(--radius); background:var(--bg-3); border:1.5px solid var(--border); cursor:pointer; transition:all var(--transition); margin-bottom:10px; }  
    .resp-check:hover { border-color:var(--border-hover); }  
    .resp-check.checked { border-color:var(--success); background:var(--success-muted); }  
    .resp-circle { width:24px; height:24px; border-radius:6px; border:2px solid var(--border); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all var(--transition); }  
    .resp-check.checked .resp-circle { background:var(--success); border-color:var(--success); }  
    .resp-circle i { color:white; font-size:10px; opacity:0; transition:opacity 0.2s; }  
    .resp-check.checked .resp-circle i { opacity:1; }

    /\* \============================================ \*/  
    /\* COUNTRY GRID                                \*/  
    /\* \============================================ \*/  
    .country-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }  
    .country-card { padding:20px; text-align:center; background:var(--bg-3); border:1.5px solid var(--border); border-radius:var(--radius); cursor:pointer; transition:all var(--transition); }  
    .country-card:hover:not(.disabled) { border-color:var(--accent); transform:translateY(-3px); box-shadow:0 8px 24px rgba(255,92,0,0.15); }  
    .country-card.disabled { opacity:0.35; cursor:not-allowed; }  
    .country-card .flag { font-size:32px; display:block; margin-bottom:8px; }  
    .country-card .c-name { font-weight:700; font-size:13px; }  
    .country-card .c-status { font-size:10px; margin-top:4px; font-weight:700; }  
    .country-card .c-status.active { color:var(--success); }  
    .country-card .c-status.soon { color:var(--text-3); }

    /\* \============================================ \*/  
    /\* ACTION SELECTOR (New vs Modify)             \*/  
    /\* \============================================ \*/  
    .action-page { position:relative; z-index:1; min-height:calc(100vh \- 56px); display:flex; align-items:center; justify-content:center; padding:40px 24px; }  
    .action-container { max-width:700px; width:100%; text-align:center; }  
    .action-container h2 { font-size:32px; font-weight:900; letter-spacing:-1px; margin-bottom:8px; }  
    .action-container p { font-size:15px; color:var(--text-2); margin-bottom:36px; }  
    .action-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:32px; }  
    .action-card { padding:32px 20px; background:var(--bg-2); border:2px solid var(--border); border-radius:var(--radius-xl); cursor:pointer; transition:all 0.3s; text-align:center; position:relative; }  
    .action-card:hover { border-color:var(--accent); transform:translateY(-6px); box-shadow:0 16px 40px rgba(0,0,0,0.3); }  
    .action-card .ac-icon { font-size:44px; display:block; margin-bottom:14px; }  
    .action-card .ac-title { font-weight:800; font-size:17px; margin-bottom:6px; }  
    .action-card .ac-desc { font-size:12px; color:var(--text-2); line-height:1.5; }  
    .action-card .ac-badge { position:absolute; top:14px; right:14px; }

    /\* \============================================ \*/  
    /\* PROMO TYPE SELECTOR                         \*/  
    /\* \============================================ \*/  
    .promo-page { position:relative; z-index:1; min-height:calc(100vh \- 56px); display:flex; align-items:center; justify-content:center; padding:40px 24px; }  
    .promo-container { max-width:740px; width:100%; }  
    .promo-container h2 { font-size:28px; font-weight:900; letter-spacing:-0.8px; margin-bottom:8px; text-align:center; }  
    .promo-container \> p { font-size:14px; color:var(--text-2); margin-bottom:32px; text-align:center; }  
    .promo-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }  
    .promo-card { padding:28px 20px; background:var(--bg-2); border:2px solid var(--border); border-radius:var(--radius-xl); cursor:pointer; transition:all 0.3s; text-align:center; }  
    .promo-card:hover { border-color:var(--accent); transform:translateY(-4px); box-shadow:0 12px 32px rgba(0,0,0,0.3); }  
    .promo-card.selected { border-color:var(--accent); background:var(--accent-glow); }  
    .promo-card .pc-icon { font-size:44px; display:block; margin-bottom:12px; }  
    .promo-card .pc-name { font-weight:800; font-size:16px; margin-bottom:4px; }  
    .promo-card .pc-desc { font-size:12px; color:var(--text-2); line-height:1.5; }

    /\* \============================================ \*/  
    /\* T\&C GENERALES SCREEN                        \*/  
    /\* \============================================ \*/  
    .tc-gen-page { position:relative; z-index:1; min-height:calc(100vh \- 56px); display:flex; align-items:center; justify-content:center; padding:40px 24px; }  
    .tc-gen-box { max-width:560px; width:100%; text-align:center; }  
    .tc-gen-icon { width:80px; height:80px; background:var(--success-muted); border:2px solid rgba(0,214,143,0.2); border-radius:24px; display:flex; align-items:center; justify-content:center; margin:0 auto 24px; font-size:36px; color:var(--success); }  
    .tc-gen-box h2 { font-size:28px; font-weight:900; margin-bottom:8px; }  
    .tc-gen-box \> p { font-size:14px; color:var(--text-2); margin-bottom:28px; line-height:1.6; }  
    .tc-link-box { background:var(--bg-2); border:2px solid var(--border); border-radius:var(--radius-lg); padding:20px; margin-bottom:20px; }  
    .tc-link-box .link-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--text-3); margin-bottom:10px; }  
    .tc-link-input { display:flex; gap:8px; }  
    .tc-link-input input { flex:1; padding:12px 14px; background:var(--bg-1); border:1.5px solid var(--border); border-radius:var(--radius); font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--accent); outline:none; }  
    .tc-link-input button { padding:12px 20px; background:var(--accent); border:none; border-radius:var(--radius); color:white; font-weight:700; cursor:pointer; font-family:'Outfit',sans-serif; transition:all var(--transition); }  
    .tc-link-input button:hover { background:var(--accent-hover); }  
    .tc-info-card { background:var(--bg-3); border:1px solid var(--border); border-radius:var(--radius); padding:18px; text-align:left; margin-bottom:20px; }  
    .tc-info-card h4 { font-size:13px; font-weight:700; margin-bottom:8px; display:flex; align-items:center; gap:8px; }  
    .tc-info-card p { font-size:12px; color:var(--text-2); line-height:1.6; }

    /\* \============================================ \*/  
    /\* MODIFY/EXTEND CAMPAIGN                      \*/  
    /\* \============================================ \*/  
    .modify-page { position:relative; z-index:1; min-height:calc(100vh \- 56px); display:flex; align-items:center; justify-content:center; padding:40px 24px; }  
    .modify-box { max-width:620px; width:100%; }  
    .modify-box h2 { font-size:28px; font-weight:900; letter-spacing:-0.8px; margin-bottom:8px; text-align:center; }  
    .modify-box \> p { font-size:14px; color:var(--text-2); margin-bottom:28px; text-align:center; }  
    .modify-card { background:var(--bg-2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:24px; margin-bottom:16px; }  
    .modify-card-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--text-3); margin-bottom:16px; display:flex; align-items:center; gap:8px; }  
    .modify-card-title i { color:var(--purple); }  
    .change-chip-grid { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:16px; }  
    .change-chip { padding:10px 16px; background:var(--bg-3); border:1.5px solid var(--border); border-radius:var(--radius); cursor:pointer; transition:all var(--transition); font-size:13px; font-weight:600; display:flex; align-items:center; gap:8px; }  
    .change-chip:hover { border-color:var(--border-hover); }  
    .change-chip.selected { border-color:var(--purple); background:var(--purple-muted); color:var(--purple); }  
    .change-chip i { font-size:14px; }

    /\* \============================================ \*/  
    /\* FORM PAGE                                   \*/  
    /\* \============================================ \*/  
    .form-layout { display:flex; min-height:calc(100vh \- 56px); position:relative; z-index:1; }  
    .form-sidebar { width:260px; flex-shrink:0; padding:28px 20px; border-right:1px solid var(--border-subtle); background:var(--bg-1); position:sticky; top:56px; height:calc(100vh \- 56px); overflow-y:auto; }  
    .sidebar-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:2px; color:var(--text-3); margin-bottom:20px; }  
    .sidebar-country { display:flex; align-items:center; gap:10px; padding:10px 14px; border-radius:var(--radius); background:var(--accent-glow); border:1px solid rgba(255,92,0,0.15); margin-bottom:24px; }  
    .sidebar-country .sc-flag { font-size:20px; }  
    .sidebar-country .sc-name { font-size:13px; font-weight:700; }  
    .sidebar-country .sc-curr { font-size:11px; color:var(--accent); font-weight:600; }

    .step-item { display:flex; align-items:flex-start; gap:12px; padding:12px 14px; border-radius:var(--radius); margin-bottom:4px; cursor:pointer; transition:all var(--transition); position:relative; }  
    .step-item:hover { background:var(--bg-3); }  
    .step-item.active { background:var(--accent-glow); }  
    .step-item.completed .s-num { background:var(--success); border-color:var(--success); color:white; }  
    .s-num { width:28px; height:28px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; background:var(--bg-3); border:1.5px solid var(--border); color:var(--text-3); flex-shrink:0; transition:all var(--transition); }  
    .step-item.active .s-num { background:var(--accent); border-color:var(--accent); color:white; box-shadow:0 0 16px rgba(255,92,0,0.4); }  
    .s-label { font-weight:600; font-size:13px; color:var(--text-1); }  
    .s-desc { font-size:11px; color:var(--text-3); margin-top:2px; }  
    .step-item.active .s-label { color:var(--accent); }  
    .step-item::after { content:''; position:absolute; left:33px; top:44px; width:2px; height:calc(100% \- 16px); background:var(--border-subtle); }  
    .step-item:last-child::after { display:none; }  
    .step-item.completed::after { background:var(--success); }

    .form-content { flex:1; padding:36px 48px 160px; max-width:740px; }  
    .form-header { margin-bottom:32px; }  
    .form-header .step-badge { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:20px; background:var(--accent-glow); border:1px solid rgba(255,92,0,0.12); font-size:11px; font-weight:700; color:var(--accent); margin-bottom:10px; text-transform:uppercase; letter-spacing:0.5px; }  
    .form-header h2 { font-size:26px; font-weight:800; letter-spacing:-0.8px; margin-bottom:6px; }  
    .form-header p { font-size:14px; color:var(--text-2); }

    .form-card { background:var(--bg-2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:24px; margin-bottom:16px; transition:all var(--transition); }  
    .form-card:hover { border-color:var(--border-hover); }  
    .form-card-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--text-3); margin-bottom:18px; display:flex; align-items:center; gap:8px; }  
    .form-card-title i { color:var(--accent); }

    /\* Inputs \*/  
    .field { margin-bottom:20px; }  
    .field:last-child { margin-bottom:0; }  
    .field-label { display:flex; align-items:center; gap:6px; font-size:13px; font-weight:600; color:var(--text-0); margin-bottom:6px; }  
    .field-label .req { color:var(--accent); font-size:14px; }  
    .field-label .icon-sm { width:18px; height:18px; border-radius:5px; background:var(--accent-glow); display:flex; align-items:center; justify-content:center; font-size:9px; color:var(--accent); }  
    .input { width:100%; padding:12px 14px; background:var(--bg-1); border:1.5px solid var(--border); border-radius:var(--radius); font-family:'Outfit',sans-serif; font-size:14px; color:var(--text-0); transition:all var(--transition); outline:none; }  
    .input::placeholder { color:var(--text-3); }  
    .input:hover { border-color:var(--border-hover); background:var(--bg-3); }  
    .input:focus { border-color:var(--accent); background:var(--bg-0); box-shadow:0 0 0 3px var(--accent-glow),0 0 16px var(--accent-glow); }  
    .input.error { border-color:var(--error); box-shadow:0 0 0 3px var(--error-muted); }  
    .input.valid { border-color:var(--success); }  
    select.input { appearance:none; padding-right:36px; background-image:url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%238888A0' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e"); background-position:right 10px center; background-repeat:no-repeat; background-size:18px; }  
    .field-hint { font-size:11px; color:var(--text-3); margin-top:5px; display:flex; align-items:center; gap:4px; }  
    .field-hint i { font-size:10px; color:var(--accent); }  
    .field-error { font-size:11px; color:var(--error); margin-top:5px; display:none; align-items:center; gap:4px; }  
    .field-error.show { display:flex; }  
    .row-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }  
    .row-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }

    /\* Type cards in form \*/  
    .type-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }  
    .type-card { padding:24px; background:var(--bg-3); border:2px solid var(--border); border-radius:var(--radius-lg); cursor:pointer; transition:all 0.25s; text-align:center; position:relative; }  
    .type-card:hover { border-color:var(--border-hover); transform:translateY(-2px); }  
    .type-card.selected { border-color:var(--accent); background:var(--accent-glow); }  
    .type-card .t-emoji { font-size:36px; display:block; margin-bottom:10px; }  
    .type-card .t-name { font-weight:800; font-size:16px; margin-bottom:4px; }  
    .type-card .t-desc { font-size:12px; color:var(--text-2); }  
    .type-card .t-check { position:absolute; top:12px; right:12px; width:22px; height:22px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; color:white; font-size:10px; opacity:0; transform:scale(0); transition:all 0.25s; }  
    .type-card.selected .t-check { opacity:1; transform:scale(1); }

    /\* Condition chips \*/  
    .cond-chips { display:flex; flex-wrap:wrap; gap:8px; }  
    .cond-chip { padding:8px 14px; background:var(--bg-3); border:1.5px solid var(--border); border-radius:20px; cursor:pointer; transition:all var(--transition); font-size:12px; font-weight:600; color:var(--text-1); }  
    .cond-chip:hover { border-color:var(--border-hover); }  
    .cond-chip.selected { border-color:var(--accent); background:var(--accent-muted); color:var(--accent); }

    /\* Bottom bar \*/  
    .bottom-bar { position:fixed; bottom:0; left:0; right:0; background:rgba(8,8,12,0.9); backdrop-filter:blur(20px); border-top:1px solid var(--border-subtle); padding:14px 24px; z-index:40; }  
    .bottom-inner { max-width:1000px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; }  
    .bottom-progress { display:flex; align-items:center; gap:14px; }  
    .progress-ring { width:40px; height:40px; }  
    .progress-ring svg { transform:rotate(-90deg); }  
    .progress-ring circle { fill:none; stroke-width:3; }  
    .progress-ring .bg { stroke:var(--border); }  
    .progress-ring .fill { stroke:var(--accent); stroke-dasharray:113; stroke-dashoffset:80; stroke-linecap:round; transition:stroke-dashoffset 0.6s cubic-bezier(0.4,0,0.2,1); filter:drop-shadow(0 0 6px rgba(255,92,0,0.5)); }  
    .progress-label { font-size:13px; color:var(--text-2); }  
    .progress-label strong { color:var(--text-0); }  
    .btn-generate { padding:12px 28px; background:linear-gradient(135deg,\#FF5C00,\#FF7A33); border:none; border-radius:var(--radius); color:white; font-family:'Outfit',sans-serif; font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:10px; transition:all var(--transition); box-shadow:0 8px 20px rgba(255,92,0,0.3); }  
    .btn-generate:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 12px 28px rgba(255,92,0,0.4); }  
    .btn-generate:disabled { opacity:0.3; cursor:not-allowed; }

    /\* Loading \*/  
    .loading-overlay { position:fixed; inset:0; background:rgba(8,8,12,0.95); z-index:70; display:flex; flex-direction:column; align-items:center; justify-content:center; }  
    .loading-spinner { width:56px; height:56px; border:3px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:spin 0.7s linear infinite; margin-bottom:20px; }

    /\* Success icon \*/  
    .success-icon { width:72px; height:72px; background:linear-gradient(135deg,var(--success),\#00F5A0); border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:30px; color:white; margin:0 auto 20px; box-shadow:0 8px 32px rgba(0,214,143,0.3); }

    /\* \============================================ \*/  
    /\* GEMINI CHATBOT                              \*/  
    /\* \============================================ \*/  
    .chat-fab { position:fixed; bottom:90px; right:24px; z-index:45; width:56px; height:56px; border-radius:16px; background:linear-gradient(135deg,\#FF5C00,\#FF7A33); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:0 8px 24px rgba(255,92,0,0.4); transition:all 0.3s; }  
    .chat-fab:hover { transform:scale(1.08); box-shadow:0 12px 32px rgba(255,92,0,0.5); }  
    .chat-fab svg { width:28px; height:28px; }

    .chat-panel { position:fixed; bottom:90px; right:24px; z-index:55; width:380px; height:520px; background:var(--bg-1); border:1px solid var(--border); border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); display:flex; flex-direction:column; animation:slideUp 0.3s cubic-bezier(0.16,1,0.3,1); overflow:hidden; }  
    .chat-header { padding:16px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; background:var(--bg-2); }  
    .chat-header-left { display:flex; align-items:center; gap:10px; }  
    .chat-header-left .chat-avatar { width:32px; height:32px; border-radius:10px; background:var(--accent-muted); display:flex; align-items:center; justify-content:center; }  
    .chat-header-left .chat-avatar svg { width:20px; height:20px; }  
    .chat-header-left h4 { font-size:14px; font-weight:700; }  
    .chat-header-left span { font-size:11px; color:var(--text-3); display:block; }  
    .chat-body { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:12px; }  
    .chat-msg { max-width:85%; padding:12px 16px; border-radius:14px; font-size:13px; line-height:1.5; }  
    .chat-msg.bot { background:var(--bg-3); border:1px solid var(--border); align-self:flex-start; border-bottom-left-radius:4px; }  
    .chat-msg.user { background:var(--accent); color:white; align-self:flex-end; border-bottom-right-radius:4px; }  
    .chat-quick-actions { padding:12px 16px; display:flex; flex-wrap:wrap; gap:6px; }  
    .chat-quick-btn { padding:7px 14px; background:var(--bg-3); border:1px solid var(--border); border-radius:20px; font-size:11px; font-weight:600; color:var(--text-1); cursor:pointer; font-family:'Outfit',sans-serif; transition:all var(--transition); }  
    .chat-quick-btn:hover { border-color:var(--accent); color:var(--accent); }  
    .chat-input-row { padding:12px 16px; border-top:1px solid var(--border); display:flex; gap:8px; }  
    .chat-input-row input { flex:1; padding:10px 14px; background:var(--bg-3); border:1px solid var(--border); border-radius:var(--radius); font-family:'Outfit',sans-serif; font-size:13px; color:var(--text-0); outline:none; }  
    .chat-input-row input:focus { border-color:var(--accent); }  
    .chat-input-row button { padding:10px 16px; background:var(--accent); border:none; border-radius:var(--radius); color:white; font-size:14px; cursor:pointer; transition:all var(--transition); }  
    .chat-input-row button:hover { background:var(--accent-hover); }

    /\* \============================================ \*/  
    /\* RADIO PRIZE CARDS                           \*/  
    /\* \============================================ \*/  
    .prize-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }  
    .prize-option { position:relative; cursor:pointer; }  
    .prize-option input { position:absolute; opacity:0; width:0; height:0; }  
    .prize-option .po-card { padding:18px; background:var(--bg-3); border:2px solid var(--border); border-radius:var(--radius); text-align:center; transition:all var(--transition); }  
    .prize-option .po-card:hover { border-color:var(--border-hover); }  
    .prize-option input:checked \+ .po-card { border-color:var(--accent); background:var(--accent-glow); }  
    .prize-option .po-icon { font-size:24px; display:block; margin-bottom:6px; }  
    .prize-option .po-name { font-weight:700; font-size:13px; }  
    .prize-option .po-desc { font-size:11px; color:var(--text-2); margin-top:2px; }

    .delivery-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }  
    .delivery-option { position:relative; cursor:pointer; }  
    .delivery-option input { position:absolute; opacity:0; width:0; height:0; }  
    .delivery-option .do-card { padding:14px; background:var(--bg-3); border:2px solid var(--border); border-radius:var(--radius); text-align:center; transition:all var(--transition); }  
    .delivery-option .do-card:hover { border-color:var(--border-hover); }  
    .delivery-option input:checked \+ .do-card { border-color:var(--purple); background:var(--purple-muted); }  
    .delivery-option .do-icon { font-size:20px; display:block; margin-bottom:4px; }  
    .delivery-option .do-name { font-weight:700; font-size:12px; }  
    .delivery-option .do-desc { font-size:10px; color:var(--text-2); margin-top:2px; }

    /\* Advanced config toggle \*/  
    .adv-toggle { display:flex; align-items:center; gap:8px; padding:12px 16px; background:var(--bg-3); border:1px solid var(--border); border-radius:var(--radius); cursor:pointer; transition:all var(--transition); margin-top:12px; }  
    .adv-toggle:hover { border-color:var(--border-hover); }  
    .adv-toggle i { color:var(--text-3); transition:transform 0.3s; font-size:12px; }  
    .adv-toggle.open i.fa-chevron-down { transform:rotate(180deg); }  
    .adv-toggle span { font-size:12px; font-weight:600; color:var(--text-2); }  
    .adv-body { display:none; padding:16px; background:var(--bg-3); border:1px solid var(--border); border-top:none; border-radius:0 0 var(--radius) var(--radius); }  
    .adv-body.open { display:block; }

    /\* Data transfer alert \*/  
    .dt-alert { background:var(--warning-muted); border:2px solid rgba(255,184,0,0.25); border-radius:var(--radius-lg); padding:20px; margin-top:16px; }  
    .dt-alert h4 { font-size:13px; font-weight:700; color:var(--warning); margin-bottom:8px; display:flex; align-items:center; gap:8px; }  
    .dt-alert p { font-size:12px; color:var(--text-1); line-height:1.6; }  
    .dt-alert ol { font-size:12px; color:var(--text-1); margin:8px 0 12px 16px; line-height:1.8; }  
    .dt-check { display:flex; align-items:flex-start; gap:10px; padding:12px; background:var(--bg-2); border:1.5px solid var(--border); border-radius:var(--radius); cursor:pointer; margin-top:12px; }  
    .dt-check:hover { border-color:var(--border-hover); }  
    .dt-check.checked { border-color:var(--success); background:var(--success-muted); }  
    .dt-check input { margin-top:2px; accent-color:var(--success); }

    /\* \============================================ \*/  
    /\* ONBOARDING TOUR                             \*/  
    /\* \============================================ \*/  
    .tour-overlay { position:fixed; inset:0; z-index:80; background:rgba(0,0,0,0.6); }  
    .tour-spotlight { position:fixed; z-index:81; border-radius:var(--radius); box-shadow:0 0 0 9999px rgba(0,0,0,0.6); transition:all 0.4s cubic-bezier(0.16,1,0.3,1); }  
    .tour-tooltip { position:fixed; z-index:82; background:var(--bg-2); border:2px solid var(--accent); border-radius:var(--radius-lg); padding:24px; max-width:340px; box-shadow:0 16px 48px rgba(0,0,0,0.5); animation:slideDown 0.3s cubic-bezier(0.16,1,0.3,1); }  
    .tour-tooltip h4 { font-size:16px; font-weight:800; margin-bottom:6px; display:flex; align-items:center; gap:8px; }  
    .tour-tooltip p { font-size:13px; color:var(--text-2); line-height:1.6; margin-bottom:16px; }  
    .tour-tooltip .tour-progress { font-size:11px; color:var(--text-3); margin-bottom:12px; }  
    .tour-actions { display:flex; justify-content:space-between; align-items:center; }  
    .tour-skip { background:none; border:none; color:var(--text-3); font-size:12px; cursor:pointer; font-family:'Outfit',sans-serif; }  
    .tour-skip:hover { color:var(--text-1); }

    /\* \============================================ \*/  
    /\* RESPONSIVE                                  \*/  
    /\* \============================================ \*/  
    @media (max-width:768px) {  
      .form-sidebar { display:none; }  
      .form-content { padding:20px 16px 160px; }  
      .row-2,.row-3 { grid-template-columns:1fr; }  
      .type-grid { grid-template-columns:1fr; }  
      .stats-row { grid-template-columns:repeat(2,1fr); }  
      .features-grid { grid-template-columns:1fr; }  
      .country-grid { grid-template-columns:repeat(2,1fr); }  
      .action-grid { grid-template-columns:1fr; }  
      .promo-grid { grid-template-columns:1fr; }  
      .hero h1 { font-size:36px; }  
      .chat-panel { width:calc(100% \- 32px); right:16px; bottom:80px; height:60vh; }  
    }  
.field-valid .input,
.field-valid input,
.field-valid select {
  border-color: var(--success) !important;
  box-shadow: 0 0 0 3px rgba(0, 214, 143, 0.1);
}
.field-error-active .input,
.field-error-active input,
.field-error-active select {
  border-color: #EF4444 !important;
  box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  animation: shake 0.3s ease;
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4px); }
  75% { transform: translateX(4px); }
}
.field-error {
  display: none;
  font-size: 11px;
  color: #EF4444;
  margin-top: 6px;
  font-weight: 600;
}
.field-error i { margin-right: 4px; }
.field-error-active .field-error { display: block !important; }
.field-valid .field-error { display: none !important; }

