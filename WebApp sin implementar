/** Envia feedback desde el modal de exito */
function sendSuccessFeedback() {
  var text = document.getElementById('successFeedbackText');
  if (!text) return;
  var feedbackText = text.value.trim();
  if (!feedbackText) { alert('Escribe tu feedback antes de enviar.'); return; }

  google.script.run
    .withSuccessHandler(function() {
      text.value = '';
      var msg = document.getElementById('successFeedbackOk');
      if (msg) {
        msg.classList.remove('hidden');
        setTimeout(function() { msg.classList.add('hidden'); }, 3000);
      }
    })
    .withFailureHandler(function(error) {
      console.error('Error enviando feedback:', error);
      alert('Error al enviar. Intenta de nuevo.');
    })
    .saveFeedback(feedbackText);
}

/** Envia feedback desde el Help Center */
function sendHelpFeedback() {
  var text = document.getElementById('helpFeedbackText');
  if (!text) return;
  var feedbackText = text.value.trim();
  if (!feedbackText) { alert('Escribe tu feedback.'); return; }

  google.script.run
    .withSuccessHandler(function() {
      text.value = '';
      alert('Gracias por tu feedback!');
    })
    .withFailureHandler(function(error) {
      alert('Error al enviar. Intenta de nuevo.');
    })
    .saveFeedback(feedbackText);
}

