    var endDate \= gv('fEndDate') ? formatDatePreview(gv('fEndDate')) : ph('FECHA FIN');  
    var startTime \= gv('fStartTime') || '00:00';  
    var endTime \= gv('fEndTime') || '23:59';  
    var shop \= gv('fShop') || ph('TIENDA');

    if (type \=== 'Cashback') {  
      var pct \= gv('fPct') || ph('%');  
      var cap \= gv('fCap') ? Number(gv('fCap')).toLocaleString('es-CO') : ph('TOPE');  
      var budget \= gv('fBudget') ? Number(gv('fBudget')).toLocaleString('es-CO') : ph('PRESUPUESTO');

      el.innerHTML \=  
        '\<h1\>TÉRMINOS Y CONDICIONES – CAMPAÑA "' \+ String(campaignName).toUpperCase() \+ '"\</h1\>' \+  
        '\<p\>Por medio del presente documento se dan a conocer los términos y condiciones de la campaña denominada "\<strong\>' \+ campaignName \+ '\</strong\>"...\</p\>' \+  
        '\<h2\>I. Territorio:\</h2\>' \+  
        '\<p\>La Campaña será válida únicamente para las órdenes realizadas en \<strong\>' \+ territory \+ '\</strong\>.\</p\>' \+  
        '\<h2\>II. Vigencia:\</h2\>' \+  
        '\<p\>Campaña válida desde las \<strong\>' \+ startTime \+ '\</strong\> del \<strong\>' \+ startDate \+ '\</strong\> hasta las \<strong\>' \+ endTime \+ '\</strong\> del \<strong\>' \+ endDate \+ '\</strong\> y/o hasta agotar existencias (' \+ budget \+ ' créditos).\</p\>' \+  
        '\<h2\>IV. Tienda Participante:\</h2\>' \+  
        '\<p\>Participará la tienda virtual \<strong\>"' \+ shop \+ '"\</strong\> al interior de la Plataforma Rappi.\</p\>' \+  
        '\<h2\>VI. Beneficio:\</h2\>' \+  
        '\<p\>Los usuarios recibirán el \<strong\>' \+ pct \+ '%\</strong\> del valor de su compra en Créditos, con un tope máximo de \<strong\>' \+ cap \+ '\</strong\> Créditos por usuario.\</p\>' \+  
        '\<p style="color:var(--text-3);font-style:italic;margin-top:16px;font-size:11px;"\>\[Vista previa simplificada \- El documento final incluirá todas las cláusulas legales\]\</p\>';  
    } else {  
      var organizer \= gv('fOrgName') || ph('ORGANIZADOR');  
      var winners \= gv('fWinners') || ph('\#');  
      var criteria \= gv('fCriteria') || 'Mayor Venta ($)';  
      var announcement \= gv('fAnnouncement') ? formatDatePreview(gv('fAnnouncement')) : ph('FECHA ANUNCIO');

      var prizeEl \= document.querySelector('input\[name="prizeType"\]:checked');  
      var prizeType \= prizeEl ? prizeEl.value : 'credits';  
      var prizeText \= '';  
      if (prizeType \=== 'credits') {  
        var amount \= gv('fCreditsAmount') ? Number(gv('fCreditsAmount')).toLocaleString('es-CO') : ph('MONTO');  
        prizeText \= '\<strong\>' \+ amount \+ '\</strong\> Créditos de la App';  
      } else {  
        prizeText \= gv('fPhysicalPrize') || ph('DESCRIPCIÓN DEL PREMIO');  
      }

      el.innerHTML \=  
        '\<h1\>TÉRMINOS Y CONDICIONES – ACTIVIDAD PROMOCIONAL "' \+ String(campaignName).toUpperCase() \+ '"\</h1\>' \+  
        '\<p\>Por medio del presente documento se dan a conocer las reglas de la actividad promocional denominada "\<strong\>' \+ campaignName \+ '\</strong\>"...\</p\>' \+  
        '\<h2\>I. Organizador y Territorio:\</h2\>' \+  
        '\<p\>La presente Actividad es organizada por \<strong\>' \+ organizer \+ '\</strong\>. Válida en \<strong\>' \+ territory \+ '\</strong\>.\</p\>' \+  
        '\<h2\>II. Vigencia:\</h2\>' \+  
        '\<p\>Desde las \<strong\>' \+ startTime \+ '\</strong\> del \<strong\>' \+ startDate \+ '\</strong\> hasta las \<strong\>' \+ endTime \+ '\</strong\> del \<strong\>' \+ endDate \+ '\</strong\>.\</p\>' \+  
        '\<h2\>IV. Mecánica:\</h2\>' \+  
        '\<p\>Ganarán los \<strong\>' \+ winners \+ '\</strong\> usuarios con el \<strong\>' \+ (criteria \=== 'Mayor Venta ($)' ? 'mayor valor acumulado en compras' : 'mayor cantidad de órdenes') \+ '\</strong\> en la tienda \<strong\>"' \+ shop \+ '"\</strong\>.\</p\>' \+  
        '\<h2\>V. Premio:\</h2\>' \+  
        '\<p\>' \+ prizeText \+ '\</p\>' \+  
        '\<h2\>VIII. Anuncio:\</h2\>' \+  
        '\<p\>Los ganadores serán anunciados el \<strong\>' \+ announcement \+ '\</strong\>.\</p\>' \+  
        '\<p style="color:var(--text-3);font-style:italic;margin-top:16px;font-size:11px;"\>\[Vista previa simplificada \- El documento final incluirá todas las cláusulas legales\]\</p\>';  
    }  
  }

  function formatDatePreview(dateStr) {  
    if (\!dateStr) return '';  
    var d \= new Date(dateStr \+ 'T12:00:00');  
    var months \= \['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'\];  
    return d.getDate() \+ ' de ' \+ months\[d.getMonth()\] \+ ' de ' \+ d.getFullYear();  
  }

  // \==========================================================  
  // PHASE 2: DRAFT INDICATOR  
  // \==========================================================  
  function showDraftIndicator() {  
    var toast \= document.getElementById('draftToast');  
    if (\!toast) return;  
    toast.classList.add('show');  
    setTimeout(function() { toast.classList.remove('show'); }, 2000);  
