<!-- JAVASCRIPT DEL ADMIN PANEL                   -->
<!-- ============================================ -->
<script>
// ============================================
// STATE
// ============================================
let currentUser = { email:'', role:'viewer', permissions:{} };
let adminTemplates = [];
let adminFields = [];

const FLAG_MAP = { CO:'🇨🇴', MX:'🇲🇽', CR:'🇨🇷', BR:'🇧🇷', AR:'🇦🇷', UY:'🇺🇾', CL:'🇨🇱', EC:'🇪🇨' };
const COUNTRY_NAMES = { CO:'Colombia', MX:'México', CR:'Costa Rica', BR:'Brasil', AR:'Argentina', UY:'Uruguay', CL:'Chile', EC:'Ecuador' };
const CURRENCY_SYMBOLS = { COP:'$', MXN:'$', CRC:'₡', BRL:'R$', ARS:'$', UYU:'$', CLP:'$', USD:'$' };
const STATUS_MAP = {
  active:         { label:'Activo',     icon:'fa-circle-check',  cls:'sts-active' },
  pending_review: { label:'En revisión',icon:'fa-clock',         cls:'sts-pending' },
  draft:          { label:'Borrador',   icon:'fa-pencil',        cls:'sts-draft' },
  approved:       { label:'Aprobado',   icon:'fa-thumbs-up',     cls:'sts-approved' },
  rejected:       { label:'Rechazado',  icon:'fa-circle-xmark',  cls:'sts-rejected' },
  inactive:       { label:'Inactivo',   icon:'fa-pause',         cls:'sts-inactive' }
};

// ============================================
// AUTH & NAVIGATION
// ============================================
function showAdminPanel() {
  // Mostrar loading mientras verifica auth
  document.getElementById('adminAuthGate').classList.remove('hidden');
  document.getElementById('authGateMessage').textContent = 'Verificando permisos...';
  document.getElementById('authGateEmail').textContent = '';

  google.script.run
    .withSuccessHandler(response => {
      const data = JSON.parse(response);

      if (data.status === 'ok') {
        currentUser = data;
        document.getElementById('adminAuthGate').classList.add('hidden');
        _openAdminPanel();
      } else if (data.status === 'unauthorized') {
        document.getElementById('authGateMessage').textContent = data.message;
        document.getElementById('authGateEmail').textContent = data.email;
      } else {
        document.getElementById('authGateMessage').textContent = data.message || 'Error de autenticación';
      }
    })
    .withFailureHandler(error => {
      document.getElementById('authGateMessage').textContent = 'Error: ' + error;
    })
    .adminGetCurrentUser();
}

function _openAdminPanel() {
  document.getElementById('landingPage').classList.add('hidden');
  try { document.getElementById('mainForm').classList.add('hidden'); } catch(e){}
  try { document.getElementById('helpCenterPage').classList.add('hidden'); } catch(e){}
  document.getElementById('adminPanel').classList.remove('hidden');

  // Set user info in nav
  document.getElementById('adminUserEmail').textContent = currentUser.email;
  document.getElementById('adminUserEmail').classList.remove('hidden');
  const roleBadge = document.getElementById('adminRoleBadge');
  roleBadge.textContent = currentUser.role;
  roleBadge.className = `px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider role-${currentUser.role}`;
  roleBadge.classList.remove('hidden');

  // Ajustar UI según permisos
  _applyPermissions();

  window.scrollTo(0, 0);
  switchAdminTab('templates');
}

function _applyPermissions() {
  const p = currentUser.permissions;
  // Ocultar botones según permisos
  _toggleEl('btnNewTemplate', p.canCreateTemplates);
  _toggleEl('btnNewField', p.canEditFields);
  _toggleEl('btnAddMember', p.canManageTeam);
  // Tab de equipo visible para todos pero solo owners gestionan
  // Tab de carpetas visible para todos
}

function _toggleEl(id, show) {
  const el = document.getElementById(id);
  if (el) el.style.display = show ? '' : 'none';
}

function hideAdminPanel() {
  document.getElementById('adminPanel').classList.add('hidden');
  document.getElementById('landingPage').classList.remove('hidden');
  window.scrollTo(0, 0);
}

function closeAuthGate() {
  document.getElementById('adminAuthGate').classList.add('hidden');
}

function switchAdminTab(tab) {
  document.querySelectorAll('.admin-panel-content').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.admin-tab').forEach(el => el.classList.remove('active'));
  document.getElementById(`panel-${tab}`).classList.remove('hidden');
  document.getElementById(`tab-${tab}`).classList.add('active');

  switch(tab) {
    case 'templates': loadAdminTemplates(); break;
    case 'fields': loadAdminFields(); break;
    case 'folders': loadFolders(); break;
    case 'countries': loadAdminCountries(); break;
    case 'team': loadTeam(); break;
    case 'logs': loadAdminLogs(); break;
    // 👇 ESTA ES LA LÍNEA NUEVA 👇
    case 'guide': break;
    case 'wizard': break;
  }
}

// ============================================
// ADMIN ACCESS BUTTON (check on page load)
// ============================================
function checkAdminAccess() {
  const btn = document.getElementById('adminBtn');
  if (btn) btn.style.display = 'flex';
}

// ============================================
// TEMPLATES
// ============================================
function loadAdminTemplates() {
  const loading = document.getElementById('templatesLoading');
  const list = document.getElementById('templatesList');
  const empty = document.getElementById('templatesEmpty');
  loading.classList.remove('hidden'); list.classList.add('hidden'); empty.classList.add('hidden');

  google.script.run
    .withSuccessHandler(response => {
      const data = JSON.parse(response);
      loading.classList.add('hidden');
      if (data.status !== 'ok' || !data.templates || data.templates.length === 0) { empty.classList.remove('hidden'); adminTemplates = []; return; }

      adminTemplates = data.templates;
      const filter = document.getElementById('filterTemplateStatus').value;
      let filtered = filter === 'ALL' ? data.templates : data.templates.filter(t => t.status === filter);

      // Count pending for badge
      const pendingCount = data.templates.filter(t => t.status === 'pending_review').length;
      const badge = document.getElementById('pendingBadge');
      if (pendingCount > 0) { badge.textContent = pendingCount; badge.classList.remove('hidden'); }
      else { badge.classList.add('hidden'); }

      if (filtered.length === 0) { empty.classList.remove('hidden'); return; }
      list.classList.remove('hidden');
      _renderTemplates(filtered, list);
    })
    .withFailureHandler(e => { loading.classList.add('hidden'); empty.classList.remove('hidden'); })
    .adminGetTemplates();
}

function _renderTemplates(templates, container) {
  const p = currentUser.permissions;
  container.innerHTML = templates.map((tpl, idx) => {
    // Find real index in adminTemplates
    const realIdx = adminTemplates.indexOf(tpl);
    const flag = FLAG_MAP[tpl.country_code] || '🌎';
    const s = STATUS_MAP[tpl.status] || STATUS_MAP['draft'];
    const typeIcon = tpl.campaign_type === 'Cashback' ? '💰' : '🏆';
    const isPending = tpl.status === 'pending_review';

    // Build action buttons based on status & permissions
    let actions = '';

    // Always: open doc
    actions += `<a href="https://docs.google.com/document/d/${tpl.template_doc_id}/edit" target="_blank" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition text-xs" title="Abrir Doc"><i class="fa-solid fa-external-link"></i></a>`;

    // Edit (editor+)
    if (p.canCreateTemplates) {
      actions += `<button onclick="editTemplate(${realIdx})" class="p-2 text-gray-500 hover:bg-gray-100 rounded-lg transition text-xs" title="Editar"><i class="fa-solid fa-pen"></i></button>`;
    }

    // Submit for review (editor+, only draft/rejected)
    if (p.canCreateTemplates && (tpl.status === 'draft' || tpl.status === 'rejected')) {
      actions += `<button onclick="submitForReview(${realIdx})" class="p-2 text-amber-600 hover:bg-amber-50 rounded-lg transition text-xs" title="Enviar a revisión"><i class="fa-solid fa-paper-plane"></i></button>`;
    }

    // Approve/Reject (admin+, only pending_review)
    if (p.canApproveTemplates && isPending) {
      actions += `<button onclick="approveTemplate(${realIdx}, false)" class="p-2 text-green-600 hover:bg-green-50 rounded-lg transition text-xs" title="Aprobar"><i class="fa-solid fa-check"></i></button>`;
      actions += `<button onclick="approveTemplate(${realIdx}, true)" class="p-2 text-emerald-600 hover:bg-emerald-50 rounded-lg transition text-xs" title="Aprobar y Activar"><i class="fa-solid fa-check-double"></i></button>`;
      actions += `<button onclick="showRejectModal(${realIdx})" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition text-xs" title="Rechazar"><i class="fa-solid fa-xmark"></i></button>`;
    }

    // Activate/Deactivate (admin+, approved or active/inactive)
    if (p.canActivateTemplates && (tpl.status === 'approved' || tpl.status === 'active' || tpl.status === 'inactive')) {
      const targetStatus = tpl.status === 'active' ? 'inactive' : 'active';
      const toggleIcon = tpl.status === 'active' ? 'fa-pause' : 'fa-play';
      const toggleColor = tpl.status === 'active' ? 'text-gray-500' : 'text-green-600';
      actions += `<button onclick="toggleStatus(${realIdx},'${targetStatus}')" class="p-2 ${toggleColor} hover:bg-gray-50 rounded-lg transition text-xs" title="${tpl.status === 'active' ? 'Desactivar' : 'Activar'}"><i class="fa-solid ${toggleIcon}"></i></button>`;
    }

    // Delete (admin+)
    if (p.canDeleteTemplates) {
      actions += `<button onclick="deleteTemplate(${realIdx})" class="p-2 text-red-400 hover:bg-red-50 rounded-lg transition text-xs" title="Eliminar"><i class="fa-solid fa-trash"></i></button>`;
    }

    // Rejection note
    let rejectionNote = '';
    if (tpl.status === 'rejected' && tpl.notes && tpl.notes.startsWith('RECHAZADO:')) {
      rejectionNote = `<div class="mt-2 bg-red-50 border border-red-200 rounded-lg p-2 text-xs text-red-700"><i class="fa-solid fa-comment-dots mr-1"></i>${tpl.notes}</div>`;
    }

    return `
      <div class="tpl-card ${isPending ? 'pending-highlight' : ''}" style="animation: fadeIn .3s ease ${idx * 0.05}s both;">
        <div class="flex flex-col sm:flex-row justify-between gap-3">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1.5">
              <span class="text-lg">${flag}</span>
              <span class="font-extrabold text-gray-900 text-sm">${COUNTRY_NAMES[tpl.country_code] || tpl.country_code}</span>
              <span class="text-gray-300">·</span>
              <span class="text-sm">${typeIcon} ${tpl.campaign_type}</span>
              <span class="sts ${s.cls}"><i class="fa-solid ${s.icon} text-[9px]"></i> ${s.label}</span>
              <span class="bg-gray-100 text-gray-500 px-2 py-0.5 rounded text-[10px] font-bold">v${tpl.version||'1.0'}</span>
            </div>
            <div class="flex items-center gap-3 text-[11px] text-gray-400">
              ${tpl.legal_owner ? `<span><i class="fa-solid fa-user mr-1"></i>${tpl.legal_owner}</span>` : ''}
              ${tpl.last_updated ? `<span><i class="fa-solid fa-calendar mr-1"></i>${tpl.last_updated}</span>` : ''}
              ${tpl.submitted_by ? `<span><i class="fa-solid fa-paper-plane mr-1"></i>${tpl.submitted_by}</span>` : ''}
              ${tpl.approved_by ? `<span><i class="fa-solid fa-check mr-1"></i>${tpl.approved_by}</span>` : ''}
            </div>
            ${rejectionNote}
          </div>
          <div class="flex items-center gap-0.5 flex-shrink-0">${actions}</div>
        </div>
      </div>
    `;
  }).join('');
}

// Template CRUD
function showAddTemplateModal() {
  document.getElementById('templateModalTitle').textContent = 'Nueva Plantilla';
  document.getElementById('tpl_editIndex').value = '-1';
  document.getElementById('templateForm').reset();
  document.getElementById('tpl_version').value = '1.0';

  // Show status control only for admin+
  const isAdmin = currentUser.permissions.canApproveTemplates;
  document.getElementById('tpl_statusControl').classList.toggle('hidden', !isAdmin);
  document.getElementById('tpl_editorNotice').classList.toggle('hidden', isAdmin);

  document.getElementById('addTemplateModal').classList.remove('hidden');
}
function hideAddTemplateModal() { document.getElementById('addTemplateModal').classList.add('hidden'); }

function editTemplate(index) {
  const tpl = adminTemplates[index]; if (!tpl) return;
  document.getElementById('templateModalTitle').textContent = 'Editar Plantilla';
  document.getElementById('tpl_editIndex').value = index;
  document.getElementById('tpl_country').value = tpl.country_code;
  document.getElementById('tpl_type').value = tpl.campaign_type;
  document.getElementById('tpl_docId').value = tpl.template_doc_id;
  document.getElementById('tpl_currency').value = tpl.currency_code || 'COP';
  document.getElementById('tpl_version').value = tpl.version || '1.0';
  document.getElementById('tpl_notes').value = tpl.notes || '';

  const isAdmin = currentUser.permissions.canApproveTemplates;
