    function handleFormSubmit(event) {
      event.preventDefault();
      
      if (!validationState.section1 || !validationState.section2 || !validationState.section3) {
        alert('⚠️ Por favor completa todos los campos requeridos antes de continuar.');
        return;
      }

      const type = document.getElementById('dynamicType').value;
      const prizeType = document.querySelector('input[name="prizeType"]:checked')?.value;
      
      if (type === 'Concurso Mayor Comprador' && prizeType === 'physical') {
        const confirmed = document.getElementById('dataTransferConfirmed').value;
        if (confirmed !== 'true') {
          showDataTransferModal();
          return;
        }
      }
      
      submitForm();
    }

    function submitForm() {
      const form = document.getElementById('legalForm');
      const loading = document.getElementById('loading');
      const btn = document.getElementById('btnSubmit');
      
      btn.disabled = true;
      loading.classList.remove('hidden');
      
      const formDataObj = new FormData(form);
      const payload = {};
      formDataObj.forEach((value, key) => payload[key] = value);
      
      if (payload.dynamicType === 'Concurso Mayor Comprador') {
        payload.prizes = payload.prizeType === 'credits' 
          ? `${payload.creditsAmount} Créditos Rappi`
          : payload.physicalPrizeDescription;
      }
      
      // Llamar a Google Apps Script
      google.script.run
        .withSuccessHandler(response => {
          const res = JSON.parse(response);
          loading.classList.add('hidden');
          
          if (res.status === 'success') {
            document.getElementById('docLink').href = res.docUrl;
            document.getElementById('resultModal').classList.remove('hidden');
            
            addToHistory(
              res.docName,
              res.docUrl,
              payload.dynamicType,
              payload.shopName
            );
            
            clearDraft();
          } else {
            alert('❌ Error: ' + res.message);
            btn.disabled = false;
          }
        })
        .withFailureHandler(error => {
          alert('❌ Error del servidor: ' + error);
          loading.classList.add('hidden');
          btn.disabled = false;
        })
        .processWebPayload(JSON.stringify(payload));
    }

